{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://msarina.moe/schema/manager/lyrics.schema.json",
  "title": "Misaka Sarina Manager Lyrics Catalog",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["title", "status"],
    "properties": {
      "title": {
        "type": "string",
        "minLength": 1
      },
      "status": {
        "type": "string",
        "enum": ["complete", "partial", "pending", "instrumental"]
      },
      "language": {
        "type": "string",
        "minLength": 2
      },
      "excerpt": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "notes": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  }
}
