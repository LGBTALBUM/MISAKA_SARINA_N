---
import '../styles/global.css';
import '../styles/mobile-header.css';
import '../styles/theme-fixes.css';
import { site, nav } from '../data/content';
const {
  title = site.title,
  description = site.description,
  image = site.image,
  ogType = 'website',
  noindex = false,
  publishedTime,
  modifiedTime,
  tags = [],
  jsonLd
} = Astro.props;
const pageTitle = title === site.title ? title : `${title} | ${site.title}`;
const canonical = new URL(Astro.url.pathname.replace(/^\/+/, ''), site.url).toString();
const absoluteImage = new URL(String(image).replace(/^\/+/, ''), site.url).toString();
const jsonLdItems = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
const withBase = (path: string) => {
  const base = import.meta.env.BASE_URL.endsWith('/')
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  return `${base}${path.replace(/^\/+/, '')}`;
};

const navKeys = ['nav.home', 'nav.music', 'nav.timeline', 'nav.friends', 'nav.business', 'nav.works', 'nav.downloads', 'nav.blog', 'nav.links', 'nav.about', 'nav.contact'];
---
<!doctype html>
<html lang="en" data-theme="dark" data-locale="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large'} />
    <meta name="author" content="Misaka Sarina" />
    <meta name="theme-color" content="#070812" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f7f3ec" media="(prefers-color-scheme: light)" />
    {tags.map((tag: string) => <meta name="keywords" content={tag} />)}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={withBase('/MSarina.svg')} />
    <link rel="alternate" type="application/rss+xml" title={`${site.title} Blog`} href={new URL('rss.xml', site.url).toString()} />
    <link rel="stylesheet" href={withBase('/home-widgets.css?v=downloads-1')} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={absoluteImage} />
    <meta property="og:image:alt" content={`${pageTitle} preview image`} />
    <meta property="og:site_name" content={site.title} />
    <meta property="og:locale" content="en_US" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {tags.map((tag: string) => <meta property="article:tag" content={tag} />)}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImage} />
    {jsonLdItems.map((item: unknown) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
    <script is:inline>
      (() => {
        const themePreference = localStorage.getItem('msarina.theme') || 'system';
        const theme = themePreference === 'light' || themePreference === 'dark'
          ? themePreference
          : (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        document.documentElement.dataset.theme = theme;
        document.documentElement.style.colorScheme = theme;
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#content" data-i18n="ui.skip">Skip to content</a>
    <header class="header wrap" data-site-header>
      <a class="brand" href={withBase('/')} aria-label="Misaka Sarina home">
        <img src={withBase('/MSarina.svg')} alt="" />
      </a>
      <button class="menu-toggle" type="button" aria-label="Toggle navigation" aria-expanded="false" data-menu-toggle>
        <span>Menu</span>
        <span aria-hidden="true"></span>
      </button>
      <div class="header-actions" data-header-actions>
        <nav class="nav" aria-label="Primary navigation">
          {nav.map(([label, href], index) => <a href={withBase(href)} data-i18n={navKeys[index]}>{label}</a>)}
        </nav>
        <div class="preference-panel" aria-label="Preferences">
          <label>
            <span data-i18n="ui.language">Language</span>
            <select data-locale-select aria-label="Language">
              <option value="system" data-i18n="ui.system">System</option>
              <option value="en">English</option>
              <option value="ja">日本語</option>
              <option value="zh-TW">中文（台灣）</option>
              <option value="ca">Català</option>
            </select>
          </label>
          <label>
            <span data-i18n="ui.theme">Theme</span>
            <select data-theme-select aria-label="Theme">
              <option value="system" data-i18n="ui.system">System</option>
              <option value="dark" data-i18n="ui.themeDark">Dark</option>
              <option value="light" data-i18n="ui.themeLight">Light</option>
            </select>
          </label>
        </div>
      </div>
    </header>
    <main id="content"><slot /></main>
    <footer class="footer wrap">
      <p>{site.copyright}</p>
      <p>
        <span data-i18n="footer.built">Built with Astro. Legacy link-page behavior now lives under</span> <a href={withBase('/links')}>/links</a>.
        <span aria-hidden="true"> · </span>
        <a href={withBase('/rss.xml')} type="application/rss+xml" data-i18n="footer.rss">RSS Feed</a>
      </p>
      <p><a href="https://icp.gov.moe/?keyword=20268295" target="_blank" rel="noreferrer">萌ICP备20268295号</a></p>
    </footer>
    <script is:inline>
      (() => {
        const header = document.querySelector('[data-site-header]');
        const toggle = document.querySelector('[data-menu-toggle]');
        const menu = document.querySelector('[data-header-actions]');

        if (!header || !toggle || !menu) return;

        const setOpen = (open) => {
          header.classList.toggle('is-menu-open', open);
          toggle.setAttribute('aria-expanded', String(open));
        };

        toggle.addEventListener('click', () => {
          setOpen(!header.classList.contains('is-menu-open'));
        });

        menu.addEventListener('click', (event) => {
          const target = event.target;
          if (target instanceof HTMLAnchorElement) setOpen(false);
        });
      })();
    </script>
    <script is:inline>
      (() => {
        const fallbackCopy = (value) => {
          const textarea = document.createElement('textarea');
          textarea.value = value;
          textarea.setAttribute('readonly', '');
          textarea.style.position = 'fixed';
          textarea.style.inset = '0 auto auto 0';
          textarea.style.opacity = '0';
          document.body.append(textarea);
          textarea.select();
          document.execCommand('copy');
          textarea.remove();
        };

        document.addEventListener('click', async (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;

          const trigger = target.closest('[data-copy-value]');
          if (!(trigger instanceof HTMLElement)) return;

          const value = trigger.dataset.copyValue;
          if (!value) return;

          event.preventDefault();
          const defaultHtml = trigger.dataset.copyHtml || trigger.innerHTML;
          trigger.dataset.copyHtml = defaultHtml;

          try {
            if (navigator.clipboard && window.isSecureContext) {
              await navigator.clipboard.writeText(value);
            } else {
              fallbackCopy(value);
            }
            trigger.textContent = trigger.dataset.copyDone || 'Copied';
            trigger.setAttribute('data-copied', 'true');
            window.setTimeout(() => {
              trigger.innerHTML = trigger.dataset.copyHtml || defaultHtml;
              trigger.removeAttribute('data-copied');
            }, 1600);
          } catch (error) {
            trigger.textContent = trigger.dataset.copyError || 'Copy failed';
            window.setTimeout(() => {
              trigger.innerHTML = trigger.dataset.copyHtml || defaultHtml;
            }, 1600);
          }
        });
      })();
    </script>
    <script src={withBase('/music-cover-fallback.js')} defer></script>
    <script src={withBase('/preferences.js')} defer></script>
    <script src={withBase('/i18n-extra.js')} defer></script>
    <script src={withBase('/content-i18n.js')} defer></script>
    <script src={withBase('/garden-i18n.js')} defer></script>
    <script src={withBase('/downloads-i18n.js')} defer></script>
    <script src={withBase('/home-widgets.js?v=downloads-1')} defer></script>
  </body>
</html>
