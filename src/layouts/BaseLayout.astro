---
import '../styles/global.css';
import { site, nav } from '../data/content';
const { title = site.title, description = site.description, image = site.image } = Astro.props;
const pageTitle = title === site.title ? title : `${title} | ${site.title}`;
const canonical = new URL(Astro.url.pathname.replace(/^\/+/, ''), site.url).toString();
const absoluteImage = new URL(String(image).replace(/^\/+/, ''), site.url).toString();
const withBase = (path: string) => {
  const base = import.meta.env.BASE_URL.endsWith('/')
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  return `${base}${path.replace(/^\/+/, '')}`;
};

const navKeys = ['nav.home', 'nav.music', 'nav.works', 'nav.blog', 'nav.links', 'nav.about', 'nav.contact'];
---
<!doctype html>
<html lang="en" data-theme="dark" data-locale="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={absoluteImage} />
    <meta property="og:site_name" content={site.title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImage} />
    <script is:inline>
      (() => {
        const themePreference = localStorage.getItem('msarina.theme') || 'system';
        const theme = themePreference === 'light' || themePreference === 'dark'
          ? themePreference
          : (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        document.documentElement.dataset.theme = theme;
        document.documentElement.style.colorScheme = theme;
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#content" data-i18n="ui.skip">Skip to content</a>
    <header class="header wrap">
      <a class="brand" href={withBase('/')} aria-label="Misaka Sarina home">MS</a>
      <div class="header-actions">
        <nav class="nav" aria-label="Primary navigation">
          {nav.map(([label, href], index) => <a href={withBase(href)} data-i18n={navKeys[index]}>{label}</a>)}
        </nav>
        <div class="preference-panel" aria-label="Preferences">
          <label>
            <span data-i18n="ui.language">Language</span>
            <select data-locale-select aria-label="Language">
              <option value="system" data-i18n="ui.system">System</option>
              <option value="en">English</option>
              <option value="ja">日本語</option>
              <option value="zh-TW">中文（台灣）</option>
              <option value="ca">Català</option>
            </select>
          </label>
          <label>
            <span data-i18n="ui.theme">Theme</span>
            <select data-theme-select aria-label="Theme">
              <option value="system" data-i18n="ui.system">System</option>
              <option value="dark" data-i18n="ui.themeDark">Dark</option>
              <option value="light" data-i18n="ui.themeLight">Light</option>
            </select>
          </label>
        </div>
      </div>
    </header>
    <main id="content"><slot /></main>
    <footer class="footer wrap">
      <p>{site.copyright}</p>
      <p><span data-i18n="footer.built">Built with Astro. Legacy link-page behavior now lives under</span> <a href={withBase('/links')}>/links</a>.</p>
    </footer>
    <script src={withBase('/music-cover-fallback.js')} defer></script>
    <script src={withBase('/preferences.js')} defer></script>
  </body>
</html>
