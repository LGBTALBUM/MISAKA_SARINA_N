---
import BaseLayout from '../layouts/BaseLayout.astro';
import { socials } from '../data/content';
import { getSortedReleases } from '../data/music';
import { getFeaturedCatalogueRelease } from '../utils/musicVisibility';

const withBase = (path: string) => {
  const base = import.meta.env.BASE_URL.endsWith('/')
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  return `${base}${path.replace(/^\/+/, '')}`;
};

const resolveAssetUrl = (url: string) => {
  if (/^https?:\/\//i.test(url)) return url;
  return withBase(url);
};

const featuredRelease = getFeaturedCatalogueRelease(getSortedReleases());
const featuredPlatforms = featuredRelease.platforms.slice(0, 3);
---
<BaseLayout>
  <section class="section hero">
    <div>
      <p class="eyebrow">Baker Siacone / Siacone Art</p>
      <h1>Misaka Sarina</h1>
      <p class="copy">Music creator / VOCALOID creator / digital project maker. 歡迎來到 Baker Siacone / Misaka Sarina 的天南星小世界。</p>
      <div class="button-row">
        <a class="button primary" href={withBase('/music')}>Listen / Music</a>
        <a class="button" href={withBase('/links')}>Links</a>
        <a class="button" href={withBase('/contact')}>Contact</a>
      </div>
    </div>
    <aside class="card hero-card">
      <div class="orb">MS</div>
      <p class="index-label">Night archive</p>
      <p>I make music, small tools, and personal spaces on the internet.</p>
      <div class="socials">{socials.map(([label, href]) => <a class="pill" href={href} target="_blank" rel="noreferrer">{label}</a>)}</div>
    </aside>
  </section>
  <section class="section card featured">
    <div class="featured-cover" aria-hidden="true">
      {featuredRelease.cover ? <img src={resolveAssetUrl(featuredRelease.cover)} alt="" /> : <span>MS</span>}
    </div>
    <div class="featured-copy">
      <p class="eyebrow">Featured Release</p>
      <h2>{featuredRelease.title}</h2>
      <p class="copy">{featuredRelease.description}</p>
      <p class="release-meta">{featuredRelease.type.toUpperCase()} · {featuredRelease.releaseDate}</p>
    </div>
    <div class="button-row featured-actions">
      <a class="button primary" href={withBase(`/music/${featuredRelease.slug}/`)}>View release</a>
      {featuredPlatforms.map((platform) => (
        <a class="button" href={platform.href} target="_blank" rel="noreferrer">{platform.label}</a>
      ))}
    </div>
  </section>
  <section class="section">
    <p class="eyebrow">Explore</p>
    <h2 class="title">A small hub for music, notes, and digital traces.</h2>
    <div class="grid">
      <a class="card tile" href={withBase('/music')}><span>Live</span><h3>Music</h3><p>Main releases first, with version entries kept in a secondary section.</p></a>
      <a class="card tile" href={withBase('/links')}><span>Live</span><h3>Links</h3><p>The organized replacement for the original Linkyee list.</p></a>
      <a class="card tile" href={withBase('/works')}><span>Reserved</span><h3>Works</h3><p>Future tools, experiments, and technical projects.</p></a>
    </div>
  </section>
</BaseLayout>
<style>.hero{display:grid;grid-template-columns:minmax(0,1.18fr) minmax(280px,.82fr);align-items:center;gap:30px;margin-top:62px}h1{margin:0;font-size:clamp(4.2rem,12vw,9.5rem);line-height:.84;letter-spacing:-.105em;text-shadow:0 18px 70px rgba(0,0,0,.55)}.hero-card{padding:28px}.index-label{margin:22px 0 4px;color:var(--accent);font-size:.78rem;font-weight:900;letter-spacing:.2em;text-transform:uppercase}.orb{display:grid;place-items:center;width:154px;height:154px;border:1px solid rgba(236,238,255,.3);border-radius:32px;color:#080914;font-size:3.5rem;font-weight:950;letter-spacing:-.12em;background:linear-gradient(135deg,#f5f2ff,#aebcff 58%,#d7b4c7);box-shadow:0 24px 90px rgba(0,0,0,.46)}.featured,.tile{padding:30px}.featured{display:grid;grid-template-columns:168px minmax(0,1fr) minmax(220px,auto);align-items:center;gap:28px}.featured-cover{display:grid;place-items:center;width:168px;aspect-ratio:1;overflow:hidden;border:1px solid rgba(236,238,255,.18);border-radius:22px;background:linear-gradient(135deg,#f5f2ff,#aebcff 58%,#d7b4c7);box-shadow:0 22px 70px rgba(0,0,0,.38)}.featured-cover img{width:100%;height:100%;object-fit:cover}.featured-cover span{color:#080914;font-size:3rem;font-weight:950;letter-spacing:-.12em}.featured-copy{min-width:0}.featured h2{margin:0 0 12px;font-size:clamp(2rem,5vw,4.2rem);letter-spacing:-.07em}.featured-actions{justify-content:flex-end}.release-meta{margin:16px 0 0;color:var(--accent-2);font-size:.78rem;font-weight:850;letter-spacing:.16em}.tile{display:flex;min-height:220px;flex-direction:column;justify-content:space-between}.tile span{width:fit-content;padding:8px 12px;border:1px solid rgba(236,238,255,.14);border-radius:999px;color:var(--accent-2);background:rgba(7,8,18,.55);font-size:.76rem;font-weight:850;letter-spacing:.16em;text-transform:uppercase}.tile h3{font-size:1.65rem;letter-spacing:-.045em}.tile p,.hero-card p{color:var(--muted)}@media(max-width:980px){.featured{grid-template-columns:132px 1fr}.featured-actions{grid-column:1 / -1;justify-content:flex-start}.featured-cover{width:132px}}@media(max-width:880px){.hero{grid-template-columns:1fr}}@media(max-width:620px){.featured{grid-template-columns:1fr}.featured-cover{width:100%;max-width:220px}.featured-actions{grid-column:auto}}</style>
