---
import BaseLayout from '../layouts/BaseLayout.astro';
import { socials } from '../data/content';
import { getSortedReleases } from '../utils/musicCatalogue';
import { getFeaturedCatalogueRelease } from '../utils/musicVisibility';

const withBase = (path: string) => {
  const base = import.meta.env.BASE_URL.endsWith('/')
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  return `${base}${path.replace(/^\/+/, '')}`;
};

const featuredRelease = getFeaturedCatalogueRelease(getSortedReleases());
const featuredPlatforms = featuredRelease.platforms.slice(0, 3);
const quickLinks = [
  ['home.quickTimelineLabel', 'home.quickTimelineBody', '/music/timeline/', 'Timeline', 'Release history by year'],
  ['home.quickGardenLabel', 'home.quickGardenBody', '/garden/', 'Garden', 'Living notes map'],
  ['home.quickFriendsLabel', 'home.quickFriendsBody', '/friends/', 'Friends', 'Neighboring sites'],
  ['home.quickBlogLabel', 'home.quickBlogBody', '/blog/', 'Blog', 'Notes and archive logs'],
  ['home.quickBusinessLabel', 'home.quickBusinessBody', '/business/', 'Business', 'Collaboration scope']
];
---
<BaseLayout>
  <section class="section hero">
    <div>
      <p class="eyebrow" data-i18n="home.eyebrow">Baker Siacone / Siacone Art</p>
      <h1>Misaka Sarina</h1>
      <p class="copy"><span data-i18n="home.copy">Music creator / VOCALOID creator / digital project maker. Welcome to the small world of Baker Siacone / Misaka Sarina.</span><br>PGP Pubkey: 213906239240F896E303A47662443ACE03F2788A</p>
      <div class="button-row">
        <a class="button primary" href={withBase('/music')} data-i18n="home.listen">Listen / Music</a>
        <a class="button" href={withBase('/garden')} data-i18n="garden.eyebrow">Digital Garden</a>
        <a class="button" href={withBase('/blog')} data-i18n="nav.blog">Blog</a>
        <a class="button" href={withBase('/business')} data-i18n="nav.business">Business</a>
        <a class="button" href={withBase('/contact')} data-i18n="home.contact">Contact</a>
      </div>
    </div>
    <aside class="card hero-card">
      <div class="orb">MS</div>
      <p class="index-label" data-i18n="home.nightArchive">Night archive</p>
      <p data-i18n="home.heroCard">I make music, small tools, and personal spaces on the internet.</p>
      <div class="socials">{socials.map(([label, href]) => <a class="pill" href={href} target="_blank" rel="noreferrer">{label}</a>)}</div>
    </aside>
  </section>

  <section class="section quick-entry" aria-label="Quick entry points">
    {quickLinks.map(([labelKey, bodyKey, href, label, note]) => (
      <a class="quick-card" href={withBase(href)}>
        <span data-i18n={labelKey}>{label}</span>
        <strong data-i18n={bodyKey}>{note}</strong>
      </a>
    ))}
  </section>

  <section class="section card featured">
    <div>
      <p class="eyebrow" data-i18n="home.featured">Featured Release</p>
      <h2>{featuredRelease.title}</h2>
      <p class="copy">{featuredRelease.description}</p>
      <p class="release-meta">{featuredRelease.type.toUpperCase()} · {featuredRelease.releaseDate}</p>
    </div>
    <div class="button-row featured-actions">
      <a class="button primary" href={withBase(`/music/${featuredRelease.slug}/`)} data-i18n="home.viewRelease">View release</a>
      {featuredPlatforms.map((platform) => (
        <a class="button" href={platform.href} target="_blank" rel="noreferrer">{platform.label}</a>
      ))}
    </div>
  </section>
  <section class="section">
    <p class="eyebrow" data-i18n="home.explore">Explore</p>
    <h2 class="title" data-i18n="home.exploreTitle">A small hub for music, notes, and digital traces.</h2>
    <div class="grid explore-grid">
      <a class="card tile" href={withBase('/music')}><span data-i18n="status.live">Live</span><h3 data-i18n="home.tileMusicTitle">Music</h3><p data-i18n="home.tileMusicBody">Main releases first, with version entries kept in a secondary section.</p></a>
      <a class="card tile" href={withBase('/music/timeline/')}><span data-i18n="status.live">Live</span><h3 data-i18n="nav.timeline">Timeline</h3><p data-i18n="home.tileTimelineBody">Sound traces by year, built from the music archive.</p></a>
      <a class="card tile" href={withBase('/garden/')}><span data-i18n="status.draft">Draft</span><h3 data-i18n="garden.eyebrow">Digital Garden</h3><p data-i18n="home.tileGardenBody">A living map for drafts, notes, release context, and maintenance traces.</p></a>
      <a class="card tile" href={withBase('/blog/')}><span data-i18n="status.draft">Draft</span><h3 data-i18n="nav.blog">Blog</h3><p data-i18n="home.tileBlogBody">Release diaries, site logs, business notes, and technical field notes.</p></a>
      <a class="card tile" href={withBase('/business/')}><span data-i18n="status.open">Open</span><h3 data-i18n="nav.business">Business</h3><p data-i18n="home.tileBusinessBody">Music, web archive, and digital project collaboration scope.</p></a>
      <a class="card tile" href={withBase('/friends/')}><span data-i18n="status.live">Live</span><h3 data-i18n="nav.friends">Friends</h3><p data-i18n="home.tileFriendsBody">Friend links, personal sites, and neighboring internet spaces.</p></a>
      <a class="card tile" href={withBase('/links')}><span data-i18n="status.live">Live</span><h3 data-i18n="home.tileLinksTitle">Links</h3><p data-i18n="home.tileLinksBody">The organized replacement for the original Linkyee list.</p></a>
    </div>
  </section>
  <section class="section card dev-trace">
    <div>
      <p class="eyebrow" data-i18n="home.digitalTrace">Digital Trace</p>
      <h2 data-i18n="home.digitalTitle">Development traces behind the archive.</h2>
      <p class="copy" data-i18n="home.digitalBody">Small tools, web experiments, infrastructure notes, and the repository history that keeps this creator space reproducible.</p>
    </div>
    <div class="trace-grid">
      <a class="trace-card" href="https://github.com/LGBTALBUM" target="_blank" rel="noreferrer">
        <span>GitHub</span>
        <strong data-i18n="home.githubProfile">Profile</strong>
        <small data-i18n="home.githubProfileBody">Development identity</small>
      </a>
      <a class="trace-card" href="https://github.com/LGBTALBUM/MISAKA_SARINA_N" target="_blank" rel="noreferrer">
        <span data-i18n="home.repository">Repository</span>
        <strong>MISAKA_SARINA_N</strong>
        <small data-i18n="home.repositoryBody">Current Astro rebuild</small>
      </a>
      <a class="trace-card" href={withBase('/works')}>
        <span data-i18n="contact.archive">Archive</span>
        <strong data-i18n="nav.works">Works</strong>
        <small data-i18n="home.worksBody">Reserved project index</small>
      </a>
      <article class="trace-card ntp-card">
        <span>NTP / UDP 123</span>
        <strong>ntp.msarina.moe</strong>
        <small>NTP service endpoint for time sync clients.</small>
        <div class="ntp-actions">
          <button class="copy-chip" type="button" data-copy-value="ntp.msarina.moe" data-copy-default="Copy endpoint" data-copy-done="Copied">Copy endpoint</button>
          <a href={withBase('/works/infrastructure-notes/')}>Details</a>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
<style>.hero{display:grid;grid-template-columns:minmax(0,1.18fr) minmax(280px,.82fr);align-items:center;gap:30px;margin-top:62px}h1{margin:0;font-size:clamp(4.2rem,12vw,9.5rem);line-height:.84;letter-spacing:-.105em;text-shadow:0 18px 70px rgba(0,0,0,.55)}.hero-card{padding:28px}.index-label{margin:22px 0 4px;color:var(--accent);font-size:.78rem;font-weight:900;letter-spacing:.2em;text-transform:uppercase}.orb{display:grid;place-items:center;width:154px;height:154px;border:1px solid rgba(236,238,255,.3);border-radius:32px;color:#080914;font-size:3.5rem;font-weight:950;letter-spacing:-.12em;background:linear-gradient(135deg,#f5f2ff,#aebcff 58%,#d7b4c7);box-shadow:0 24px 90px rgba(0,0,0,.46)}.quick-entry{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:12px;margin-top:-22px}.quick-card{display:grid;gap:8px;border:1px solid rgba(236,238,255,.12);border-radius:18px;background:rgba(7,8,18,.46);padding:16px 18px;transition:transform 160ms ease,border-color 160ms ease,background 160ms ease}.quick-card:hover,.quick-card:focus-visible{transform:translateY(-2px);border-color:rgba(217,210,255,.45);background:rgba(19,22,42,.72)}.quick-card span{color:var(--accent-2);font-size:.72rem;font-weight:900;letter-spacing:.16em;text-transform:uppercase}.quick-card strong{font-size:.95rem;line-height:1.25}.featured,.tile,.dev-trace{padding:30px}.featured{display:grid;grid-template-columns:minmax(0,1fr) minmax(220px,auto);align-items:center;gap:24px}.featured h2,.dev-trace h2{margin:0 0 12px;font-size:clamp(2rem,5vw,4.2rem);letter-spacing:-.07em}.featured-actions{justify-content:flex-end}.release-meta{margin:16px 0 0;color:var(--accent-2);font-size:.78rem;font-weight:850;letter-spacing:.16em}.explore-grid{grid-template-columns:repeat(3,minmax(0,1fr))}.tile{display:flex;min-height:220px;flex-direction:column;justify-content:space-between}.tile span{width:fit-content;padding:8px 12px;border:1px solid rgba(236,238,255,.14);border-radius:999px;color:var(--accent-2);background:rgba(7,8,18,.55);font-size:.76rem;font-weight:850;letter-spacing:.16em;text-transform:uppercase}.tile h3{font-size:1.65rem;letter-spacing:-.045em}.tile p,.hero-card p{color:var(--muted)}.dev-trace{display:grid;grid-template-columns:minmax(0,0.9fr) minmax(320px,1.1fr);gap:28px;align-items:center;margin-bottom:24px}.trace-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}.trace-card{display:grid;gap:8px;border:1px solid rgba(236,238,255,.12);border-radius:18px;background:rgba(7,8,18,.48);padding:18px;transition:transform 160ms ease,border-color 160ms ease,background 160ms ease}.trace-card:hover,.trace-card:focus-visible{transform:translateY(-2px);border-color:rgba(217,210,255,.45);background:rgba(19,22,42,.72)}.trace-card span{color:var(--soft);font-size:.72rem;font-weight:850;letter-spacing:.16em;text-transform:uppercase}.trace-card strong{font-size:1.05rem}.trace-card small{color:var(--soft);line-height:1.45}.ntp-card strong{font-size:1.1rem;letter-spacing:-.025em;word-break:break-all}.ntp-actions{display:flex;flex-wrap:wrap;gap:8px;margin-top:4px}.ntp-actions a,.copy-chip{display:inline-flex;align-items:center;min-height:36px;border:1px solid rgba(236,238,255,.12);border-radius:999px;background:rgba(7,8,18,.42);color:var(--text);padding:0 12px;font:inherit;font-size:.8rem;font-weight:850;cursor:pointer;transition:transform 160ms ease,border-color 160ms ease,background 160ms ease}.ntp-actions a:hover,.ntp-actions a:focus-visible,.copy-chip:hover,.copy-chip:focus-visible{transform:translateY(-1px);border-color:rgba(217,210,255,.45);background:rgba(19,22,42,.72)}.copy-chip[data-copied="true"]{border-color:rgba(168,184,255,.42)}@media(max-width:1180px){.quick-entry{grid-template-columns:repeat(3,minmax(0,1fr))}.trace-grid{grid-template-columns:repeat(2,minmax(0,1fr))}}@media(max-width:1020px){.explore-grid{grid-template-columns:repeat(2,minmax(0,1fr))}}@media(max-width:920px){.dev-trace,.trace-grid{grid-template-columns:1fr}}@media(max-width:880px){.hero,.featured{grid-template-columns:1fr}.featured-actions{justify-content:flex-start}.quick-entry{margin-top:0;grid-template-columns:repeat(2,minmax(0,1fr))}}@media(max-width:560px){.quick-entry,.explore-grid{grid-template-columns:1fr}}</style>
