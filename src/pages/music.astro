---
import BaseLayout from '../layouts/BaseLayout.astro';
import MusicCard from '../components/MusicCard.astro';
import { getSortedReleases } from '../data/music';

const releases = getSortedReleases();
---

<BaseLayout title="Music" description="Music catalogue for Misaka Sarina releases, profiles, and sound experiments.">
  <section class="section">
    <p class="eyebrow">Music</p>
    <h1 class="title">Releases and sound traces.</h1>
    <p class="copy">A lightweight catalogue for Misaka Sarina music entries. Each item can point to streaming platforms, credits, production notes, and future lyrics pages.</p>
  </section>

  <section class="music-list" aria-label="Music releases">
    {releases.map((release) => <MusicCard release={release} />)}
  </section>
</BaseLayout>

<style>
  .music-list {
    display: grid;
    gap: 18px;
    margin: 0 0 80px;
  }
</style>
