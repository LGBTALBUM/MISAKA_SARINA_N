---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/content';
const withBase = (path: string) => {
  const base = import.meta.env.BASE_URL.endsWith('/')
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  return `${base}${path.replace(/^\/+/, '')}`;
};
---
<BaseLayout title="Contact" description="Contact entry points for Misaka Sarina collaboration or project inquiries.">
  <section class="section contact-hero card">
    <div>
      <p class="eyebrow" data-i18n="contact.eyebrow">Contact</p>
      <h1 class="title" data-i18n="contact.title">Tell me about your project.</h1>
      <p class="copy" data-i18n="contact.copy">For music production, collaboration, licensing, release-related questions, or digital project inquiries, use one of the contact routes below.</p>
    </div>
    <div class="mail-card">
      <span data-i18n="contact.primaryEmail">Primary email</span>
      <strong>{site.email}</strong>
      <a class="button primary" href={`mailto:${site.email}`} data-i18n="contact.writeEmail">Write email</a>
    </div>
  </section>

  <section class="section contact-grid">
    <a class="card contact-card" href="https://soundbetter.com/profiles/701882-misaka-sarina" target="_blank" rel="noreferrer">
      <span data-i18n="contact.production">Production</span>
      <strong>SoundBetter</strong>
      <small data-i18n="contact.soundbetter">Music production profile</small>
    </a>
    <a class="card contact-card" href="https://www.instagram.com/misakasarina/" target="_blank" rel="noreferrer">
      <span data-i18n="contact.social">Social</span>
      <strong>Instagram</strong>
      <small data-i18n="contact.instagram">Updates and direct contact</small>
    </a>
    <a class="card contact-card" href={withBase('/links')}>
      <span data-i18n="contact.archive">Archive</span>
      <strong data-i18n="contact.allLinks">All Links</strong>
      <small data-i18n="contact.allLinksCopy">Full external link collection</small>
    </a>
  </section>
</BaseLayout>
<style>
  .contact-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.42fr);
    gap: 28px;
    align-items: end;
    padding: clamp(28px, 6vw, 56px);
  }

  .mail-card,
  .contact-card {
    border: 1px solid rgba(236, 238, 255, 0.12);
    border-radius: 20px;
    background: rgba(7, 8, 18, 0.52);
  }

  .mail-card {
    display: grid;
    gap: 14px;
    padding: 22px;
  }

  .mail-card span,
  .contact-card span {
    color: var(--soft);
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .mail-card strong {
    color: var(--accent);
    word-break: break-all;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .contact-card {
    display: grid;
    gap: 10px;
    padding: 24px;
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
  }

  .contact-card:hover,
  .contact-card:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(217, 210, 255, 0.45);
    background: rgba(19, 22, 42, 0.72);
  }

  .contact-card strong {
    font-size: 1.3rem;
  }

  .contact-card small {
    color: var(--soft);
  }

  @media (max-width: 840px) {
    .contact-hero,
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
