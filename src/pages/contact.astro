---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/content';
import { businessOfferings } from '../data/business';

const withBase = (path: string) => {
  const base = import.meta.env.BASE_URL.endsWith('/')
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  return `${base}${path.replace(/^\/+/, '')}`;
};
---
<BaseLayout title="Contact" description="Contact entry points for Misaka Sarina collaboration, business, licensing, or project inquiries.">
  <section class="section contact-hero card">
    <div>
      <p class="eyebrow" data-i18n="contact.eyebrow">Contact</p>
      <h1 class="title" data-i18n="contact.titleNew">Start with a clear brief.</h1>
      <p class="copy" data-i18n="contact.copyNew">For music production, collaboration, licensing, web archive work, or digital project inquiries, send a compact message with enough context to make the first reply useful.</p>
      <div class="button-row hero-actions">
        <a class="button primary" href={`mailto:${site.email}?subject=Project%20Inquiry%20for%20Misaka%20Sarina`} data-i18n="contact.emailDirectly">Email directly</a>
        <a class="button" href={withBase('/business/')} data-i18n="contact.viewBusinessScope">View business scope</a>
      </div>
    </div>
    <div class="mail-card">
      <span data-i18n="contact.primaryEmail">Primary email</span>
      <strong>{site.email}</strong>
      <p data-i18n="contact.mailNote">Best for scoped inquiries, licensing questions, collaboration requests, and production work.</p>
    </div>
  </section>

  <section class="section card brief-card">
    <div>
      <p class="eyebrow" data-i18n="contact.beforeWriting">Before writing</p>
      <h2 data-i18n="contact.goodMessageTitle">What makes a good first message?</h2>
      <p class="copy" data-i18n="contact.goodMessageCopy">A good first message does not need to be long. It should be specific enough to understand the goal, timing, and whether the work fits.</p>
    </div>
    <ul>
      <li data-i18n="contact.briefProject">Project type and expected outcome</li>
      <li data-i18n="contact.briefReferences">Reference links or existing materials</li>
      <li data-i18n="contact.briefDeadline">Deadline, launch window, or urgency</li>
      <li data-i18n="contact.briefBudget">Budget range or collaboration model</li>
      <li data-i18n="contact.briefTimezone">Preferred contact route and timezone</li>
    </ul>
  </section>

  <section class="section route-grid" aria-label="Contact routes">
    <a class="card contact-card feature" href={`mailto:${site.email}?subject=Music%20Production%20Inquiry`}>
      <span data-i18n="contact.musicLicensing">Music / Licensing</span>
      <strong data-i18n="contact.productionInquiry">Production, release, or usage inquiry</strong>
      <small data-i18n="contact.productionInquiryCopy">Use email for work that needs context, files, credits, rights, or timeline discussion.</small>
    </a>
    <a class="card contact-card" href="https://soundbetter.com/profiles/701882-misaka-sarina" target="_blank" rel="noreferrer">
      <span data-i18n="contact.production">Production</span>
      <strong>SoundBetter</strong>
      <small data-i18n="contact.soundbetter">Music production profile</small>
    </a>
    <a class="card contact-card" href="https://www.instagram.com/misakasarina/" target="_blank" rel="noreferrer">
      <span data-i18n="contact.social">Social</span>
      <strong>Instagram</strong>
      <small data-i18n="contact.instagram">Updates and direct contact</small>
    </a>
    <a class="card contact-card" href={withBase('/business/')}>
      <span data-i18n="nav.business">Business</span>
      <strong data-i18n="contact.collaborationScope">Collaboration scope</strong>
      <small data-i18n="contact.collaborationScopeCopy">Music, web archive, and digital project consulting details.</small>
    </a>
    <a class="card contact-card" href={withBase('/links')}>
      <span data-i18n="contact.archive">Archive</span>
      <strong data-i18n="contact.allLinks">All Links</strong>
      <small data-i18n="contact.allLinksCopy">Full external link collection</small>
    </a>
  </section>

  <section class="section card service-map">
    <div class="section-heading">
      <p class="eyebrow" data-i18n="contact.projectLanes">Project lanes</p>
      <h2 data-i18n="contact.chooseLane">Choose the closest lane.</h2>
      <p class="copy" data-i18n="contact.chooseLaneCopy">The message can be simple. Pick the closest lane and describe the desired result.</p>
    </div>
    <div class="lane-grid">
      {businessOfferings.map((offering) => (
        <a href={withBase(`/business/#${offering.slug}`)}>
          <span>{offering.eyebrow}</span>
          <strong>{offering.title}</strong>
          <small>{offering.summary}</small>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
<style>
  .contact-hero,
  .brief-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.42fr);
    gap: 28px;
    align-items: end;
    padding: clamp(28px, 6vw, 56px);
  }

  .hero-actions {
    margin-top: 26px;
  }

  .mail-card,
  .contact-card,
  .lane-grid a {
    border: 1px solid rgba(236, 238, 255, 0.12);
    border-radius: 20px;
    background: rgba(7, 8, 18, 0.52);
  }

  .mail-card {
    display: grid;
    gap: 14px;
    padding: 22px;
  }

  .mail-card span,
  .contact-card span,
  .lane-grid span {
    color: var(--soft);
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .mail-card strong {
    color: var(--accent);
    word-break: break-all;
  }

  .mail-card p,
  .brief-card li,
  .contact-card small,
  .lane-grid small {
    color: var(--muted);
    line-height: 1.62;
  }

  .brief-card {
    align-items: center;
  }

  .brief-card h2,
  .service-map h2 {
    margin: 0 0 12px;
    font-size: clamp(1.9rem, 5vw, 3.4rem);
    line-height: 0.96;
    letter-spacing: -0.07em;
  }

  .brief-card ul {
    display: grid;
    gap: 10px;
    margin: 0;
    padding-left: 20px;
  }

  .route-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .contact-card {
    display: grid;
    gap: 10px;
    min-height: 190px;
    align-content: space-between;
    padding: 24px;
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
  }

  .contact-card.feature {
    grid-column: span 2;
  }

  .contact-card:hover,
  .contact-card:focus-visible,
  .lane-grid a:hover,
  .lane-grid a:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(217, 210, 255, 0.45);
    background: rgba(19, 22, 42, 0.72);
  }

  .contact-card strong {
    font-size: clamp(1.25rem, 3vw, 1.8rem);
    line-height: 1.08;
    letter-spacing: -0.04em;
  }

  .service-map {
    padding: clamp(28px, 6vw, 44px);
  }

  .section-heading {
    margin-bottom: 26px;
  }

  .lane-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .lane-grid a {
    display: grid;
    gap: 10px;
    padding: 18px;
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
  }

  .lane-grid strong {
    font-size: 1.15rem;
    line-height: 1.12;
  }

  @media (max-width: 900px) {
    .route-grid,
    .lane-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 720px) {
    .contact-hero,
    .brief-card,
    .route-grid,
    .lane-grid {
      grid-template-columns: 1fr;
    }

    .contact-card.feature {
      grid-column: auto;
    }
  }
</style>
