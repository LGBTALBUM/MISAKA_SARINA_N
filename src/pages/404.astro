---
import BaseLayout from '../layouts/BaseLayout.astro';
const homeUrl = import.meta.env.BASE_URL;
---
<BaseLayout title="Not Found" description="The requested page could not be found.">
  <section class="section card page-card">
    <p class="eyebrow">404</p>
    <h1 class="title">Signal not found.</h1>
    <p class="copy">The page you are looking for does not exist yet.</p>
    <a class="button primary" href={homeUrl}>Back home</a>
  </section>
</BaseLayout>
<style>.page-card{padding:clamp(28px,6vw,56px)}</style>
