---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSortedReleases } from '../utils/musicCatalogue';
import {
  getMainCatalogueReleases,
  getProfileEntries,
  getSecondaryReleases
} from '../utils/musicVisibility';

const releases = getSortedReleases();
const mainReleases = getMainCatalogueReleases(releases);
const secondaryReleases = getSecondaryReleases(releases);
const profileEntries = getProfileEntries(releases);
const manualEntries = releases.filter((release) => release.source?.label === 'Manual catalogue');
const noPublicLinks = releases.filter((release) => release.platforms.length === 0);
const manualNoPublicLinks = manualEntries.filter((release) => release.platforms.length === 0);
const featuredCandidates = releases.filter((release) => release.featuredCandidate);
const needsReview = releases.filter((release) => release.needsReview);

const normalizeDuplicateKey = (title: string) =>
  title
    .toLowerCase()
    .replace(/\[[^\]]*\]/g, '')
    .replace(/\([^)]*\)/g, '')
    .replace(/（[^）]*）/g, '')
    .replace(/【[^】]*】/g, '')
    .replace(/\s+/g, ' ')
    .trim();

const duplicateGroups = Object.values(
  releases.reduce<Record<string, typeof releases>>((groups, release) => {
    const key = normalizeDuplicateKey(release.title);
    if (!key) return groups;
    groups[key] = groups[key] ?? [];
    groups[key].push(release);
    return groups;
  }, {})
).filter((group) => group.length > 1);

const reviewRows = [
  ['Total resolved entries', releases.length],
  ['Primary catalogue', mainReleases.length],
  ['Secondary entries', secondaryReleases.length],
  ['Profile entries', profileEntries.length],
  ['Manual catalogue entries', manualEntries.length],
  ['Entries without public links', noPublicLinks.length],
  ['Manual entries without public links', manualNoPublicLinks.length],
  ['Featured candidates', featuredCandidates.length],
  ['Needs review', needsReview.length],
  ['Possible duplicate title groups', duplicateGroups.length]
];

const withBase = (path: string) => {
  const base = import.meta.env.BASE_URL.endsWith('/')
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  return `${base}${path.replace(/^\/+/, '')}`;
};

const sectionLimit = 60;
---
<BaseLayout title="Catalogue Review" description="Internal catalogue review dashboard for Misaka Sarina music data.">
  <section class="section card review-hero">
    <div>
      <p class="eyebrow">Catalogue Review</p>
      <h1 class="title">Music data health dashboard.</h1>
      <p class="copy">A static review page for checking VocaDB generated entries, YTM-derived manual entries, quality flags, missing public links, and possible duplicate titles.</p>
    </div>
    <div class="hero-actions">
      <a class="button primary" href={withBase('/music')}>Back to music</a>
      <a class="button" href="https://github.com/LGBTALBUM/MISAKA_SARINA_N/blob/main/src/data/manualMusicQuality.ts" target="_blank" rel="noreferrer">Quality file</a>
    </div>
  </section>

  <section class="section stats-grid" aria-label="Catalogue review stats">
    {reviewRows.map(([label, value]) => (
      <article class="card stat-card">
        <span>{label}</span>
        <strong>{value}</strong>
      </article>
    ))}
  </section>

  <section class="section card review-section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Featured candidates</p>
        <h2>Potential highlights</h2>
      </div>
      <span>{featuredCandidates.length} entries</span>
    </div>
    {featuredCandidates.length > 0 ? (
      <div class="review-list">
        {featuredCandidates.map((release) => <a class="review-row" href={withBase(`/music/${release.slug}/`)}><b>{release.title}</b><small>{release.releaseDate} · {release.source?.label ?? 'Generated'} · {release.platforms.length} links</small></a>)}
      </div>
    ) : <p class="empty">No featured candidates yet.</p>}
  </section>

  <section class="section card review-section">
    <div class="section-head">
      <div>
        <p class="eyebrow">No public links</p>
        <h2>Entries missing platform URLs</h2>
      </div>
      <span>{noPublicLinks.length} entries</span>
    </div>
    <p class="hint">Showing up to {sectionLimit} entries. Add public track URLs through <code>manualMusicQuality.ts</code> or <code>musicOverrides.ts</code>.</p>
    <div class="review-list">
      {noPublicLinks.slice(0, sectionLimit).map((release) => <a class="review-row" href={withBase(`/music/${release.slug}/`)}><b>{release.title}</b><small>{release.releaseDate} · {release.source?.label ?? 'Generated'} · {release.slug}</small></a>)}
    </div>
  </section>

  <section class="section card review-section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Needs review</p>
        <h2>Manual curation queue</h2>
      </div>
      <span>{needsReview.length} entries</span>
    </div>
    {needsReview.length > 0 ? (
      <div class="review-list">
        {needsReview.map((release) => <a class="review-row" href={withBase(`/music/${release.slug}/`)}><b>{release.title}</b><small>{release.releaseDate} · {release.source?.label ?? 'Generated'} · {release.slug}</small></a>)}
      </div>
    ) : <p class="empty">No entries are marked as needsReview.</p>}
  </section>

  <section class="section card review-section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Possible duplicates</p>
        <h2>Normalized title groups</h2>
      </div>
      <span>{duplicateGroups.length} groups</span>
    </div>
    {duplicateGroups.length > 0 ? (
      <div class="duplicate-list">
        {duplicateGroups.map((group) => (
          <article class="duplicate-group">
            <h3>{normalizeDuplicateKey(group[0].title)}</h3>
            <div class="review-list">
              {group.map((release) => <a class="review-row" href={withBase(`/music/${release.slug}/`)}><b>{release.title}</b><small>{release.releaseDate} · {release.source?.label ?? 'Generated'} · {release.slug}</small></a>)}
            </div>
          </article>
        ))}
      </div>
    ) : <p class="empty">No possible duplicate title groups found.</p>}
  </section>

  <section class="section card review-section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Manual catalogue</p>
        <h2>YTM-derived entries</h2>
      </div>
      <span>{manualEntries.length} entries</span>
    </div>
    <p class="hint">Showing up to {sectionLimit} entries. Private playlist URLs are not stored or displayed.</p>
    <div class="review-list">
      {manualEntries.slice(0, sectionLimit).map((release) => <a class="review-row" href={withBase(`/music/${release.slug}/`)}><b>{release.title}</b><small>{release.releaseDate} · {release.platforms.length} public links · {release.slug}</small></a>)}
    </div>
  </section>
</BaseLayout>
<style>
  .review-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(240px, auto);
    gap: 28px;
    align-items: end;
    padding: clamp(28px, 6vw, 56px);
  }

  .hero-actions {
    display: grid;
    gap: 12px;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 14px;
  }

  .stat-card {
    display: grid;
    gap: 12px;
    padding: 20px;
  }

  .stat-card span,
  .section-head > span {
    color: var(--soft);
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .stat-card strong {
    color: var(--accent);
    font-size: 2rem;
    line-height: 1;
  }

  .review-section {
    padding: clamp(24px, 5vw, 38px);
  }

  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 20px;
    margin-bottom: 22px;
  }

  .section-head h2 {
    margin: 0;
    font-size: clamp(1.8rem, 4.5vw, 3.2rem);
    line-height: 0.96;
    letter-spacing: -0.06em;
  }

  .section-head > span {
    border: 1px solid rgba(236, 238, 255, 0.13);
    border-radius: 999px;
    background: rgba(7, 8, 18, 0.52);
    padding: 8px 12px;
    white-space: nowrap;
  }

  .hint,
  .empty {
    color: var(--muted);
    line-height: 1.7;
  }

  code {
    border: 1px solid rgba(236, 238, 255, 0.13);
    border-radius: 8px;
    background: rgba(7, 8, 18, 0.52);
    padding: 2px 6px;
  }

  .review-list,
  .duplicate-list {
    display: grid;
    gap: 10px;
  }

  .review-row,
  .duplicate-group {
    border: 1px solid rgba(236, 238, 255, 0.12);
    border-radius: 18px;
    background: rgba(7, 8, 18, 0.48);
  }

  .review-row {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    padding: 14px 16px;
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
  }

  .review-row:hover,
  .review-row:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(217, 210, 255, 0.45);
    background: rgba(19, 22, 42, 0.72);
  }

  .review-row small {
    color: var(--soft);
    text-align: right;
  }

  .duplicate-group {
    padding: 16px;
  }

  .duplicate-group h3 {
    margin: 0 0 12px;
    color: var(--accent);
    font-size: 1.2rem;
  }

  @media (max-width: 820px) {
    .review-hero,
    .section-head,
    .review-row {
      grid-template-columns: 1fr;
      flex-direction: column;
      align-items: flex-start;
    }

    .review-row small {
      text-align: left;
    }
  }
</style>
