---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSortedReleases } from '../utils/musicCatalogue';
import {
  getMainCatalogueReleases,
  getProfileEntries,
  getSecondaryReleases
} from '../utils/musicVisibility';
import { resolveMusicCover } from '../utils/musicCover';

const releases = getSortedReleases();
const mainReleases = getMainCatalogueReleases(releases);
const secondaryReleases = getSecondaryReleases(releases);
const profileEntries = getProfileEntries(releases);
const manualEntries = releases.filter((release) => release.source?.label === 'Manual catalogue');
const noPublicLinks = releases.filter((release) => release.platforms.length === 0);
const manualNoPublicLinks = manualEntries.filter((release) => release.platforms.length === 0);
const featuredCandidates = releases.filter((release) => release.featuredCandidate);
const needsReview = releases.filter((release) => release.needsReview);
const coverDiagnostics = releases.map((release) => ({ release, cover: resolveMusicCover(release, import.meta.env.BASE_URL) }));
const withCover = coverDiagnostics.filter((item) => item.cover.hasCover);
const withoutCover = coverDiagnostics.filter((item) => !item.cover.hasCover);
const squareCandidateCovers = coverDiagnostics.filter((item) => item.cover.strategy === 'square');
const sourceCovers = coverDiagnostics.filter((item) => item.cover.strategy === 'source');
const placeholderCovers = coverDiagnostics.filter((item) => item.cover.strategy === 'placeholder');

const normalizeDuplicateKey = (title: string) =>
  title
    .toLowerCase()
    .replace(/\[[^\]]*\]/g, '')
    .replace(/\([^)]*\)/g, '')
    .replace(/（[^）]*）/g, '')
    .replace(/【[^】]*】/g, '')
    .replace(/\s+/g, ' ')
    .trim();

const duplicateGroups = Object.values(
  releases.reduce<Record<string, typeof releases>>((groups, release) => {
    const key = normalizeDuplicateKey(release.title);
    if (!key) return groups;
    groups[key] = groups[key] ?? [];
    groups[key].push(release);
    return groups;
  }, {})
).filter((group) => group.length > 1);

const reviewRows = [
  ['Total resolved entries', releases.length, 'all'],
  ['Primary catalogue', mainReleases.length, 'primary'],
  ['Secondary entries', secondaryReleases.length, 'secondary'],
  ['Profile entries', profileEntries.length, 'profiles'],
  ['Manual catalogue entries', manualEntries.length, 'manual'],
  ['Entries without public links', noPublicLinks.length, 'no-links'],
  ['Manual entries without public links', manualNoPublicLinks.length, 'manual-no-links'],
  ['Featured candidates', featuredCandidates.length, 'featured'],
  ['Needs review', needsReview.length, 'needs-review'],
  ['Possible duplicate title groups', duplicateGroups.length, 'duplicates'],
  ['Entries with cover', withCover.length, 'covers'],
  ['Entries without cover', withoutCover.length, 'cover-missing'],
  ['Square cover candidates', squareCandidateCovers.length, 'cover-square'],
  ['Source cover only', sourceCovers.length, 'cover-source'],
  ['MS placeholder', placeholderCovers.length, 'cover-placeholder']
];

const withBase = (path: string) => {
  const base = import.meta.env.BASE_URL.endsWith('/')
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  return `${base}${path.replace(/^\/+/, '')}`;
};

const sectionLimit = 100;
const quickLinks = [
  ['Stats', '#stats'],
  ['Covers', '#covers'],
  ['Featured', '#featured'],
  ['No public links', '#no-public-links'],
  ['Needs review', '#needs-review'],
  ['Duplicates', '#duplicates'],
  ['Manual', '#manual']
];

const rowData = (release: typeof releases[number], tags: string[] = []) => ({
  search: [release.title, release.slug, release.releaseDate, release.source?.label ?? 'Generated', ...tags].join(' ').toLowerCase(),
  tags: tags.join(' ')
});
---
<BaseLayout title="Catalogue Review" description="Internal catalogue review dashboard for Misaka Sarina music data.">
  <section class="section card review-hero">
    <div>
      <p class="eyebrow">Catalogue Review</p>
      <h1 class="title">Music data health dashboard.</h1>
      <p class="copy">A static review page for checking generated entries, manual entries, quality flags, missing public links, duplicate titles, and cover fallback status.</p>
    </div>
    <div class="hero-actions">
      <a class="button primary" href={withBase('/music')}>Back to music</a>
      <a class="button" href="https://github.com/LGBTALBUM/MISAKA_SARINA_N/blob/main/src/data/manualMusicQuality.ts" target="_blank" rel="noreferrer">Quality file</a>
    </div>
  </section>

  <section class="review-tools card" aria-label="Catalogue review tools">
    <div class="quick-links">
      {quickLinks.map(([label, href]) => <a href={href}>{label}</a>)}
    </div>
    <div class="filter-bar">
      <label>
        <span>Search</span>
        <input data-catalogue-search type="search" placeholder="Title, slug, source, tag…" />
      </label>
      <div class="filter-buttons" aria-label="Quick filters">
        <button type="button" data-filter="all" class="active">All</button>
        <button type="button" data-filter="manual">Manual</button>
        <button type="button" data-filter="no-links">No links</button>
        <button type="button" data-filter="featured">Featured</button>
        <button type="button" data-filter="needs-review">Needs review</button>
        <button type="button" data-filter="cover-missing">No cover</button>
        <button type="button" data-filter="cover-square">Square cover</button>
      </div>
      <p data-filter-status class="filter-status">Showing all review rows.</p>
    </div>
  </section>

  <section id="stats" class="section stats-grid" aria-label="Catalogue review stats">
    {reviewRows.map(([label, value, anchor]) => (
      <a class="card stat-card" href={`#${anchor}`}>
        <span>{label}</span>
        <strong>{value}</strong>
      </a>
    ))}
  </section>

  <section id="covers" class="section card review-section" data-review-section>
    <div class="section-head">
      <div>
        <p class="eyebrow">Cover diagnostics</p>
        <h2>Artwork fallback status</h2>
      </div>
      <span>{coverDiagnostics.length} entries</span>
    </div>
    <p class="hint">Showing up to {sectionLimit} entries. Cover strategy is resolved as <code>square</code>, <code>source</code>, or <code>placeholder</code>. Browser runtime may still fall back from square candidate to original source if the square image URL fails.</p>
    <div class="review-list">
      {coverDiagnostics.slice(0, sectionLimit).map(({ release, cover }) => {
        const tags = [
          'cover',
          cover.hasCover ? 'has-cover' : 'cover-missing',
          `cover-${cover.strategy}`,
          release.source?.label === 'Manual catalogue' ? 'manual' : 'generated',
          release.platforms.length === 0 ? 'no-links' : 'has-links'
        ];
        const data = rowData(release, tags);
        return (
          <a class="review-row" data-review-row data-search={data.search} data-tags={data.tags} data-cover-primary={cover.primary ?? ''} data-cover-fallback={cover.fallback ?? ''} href={withBase(`/music/${release.slug}/`)}>
            <b>{release.title}</b>
            <small>{release.releaseDate} · {cover.strategy} · {cover.hasCover ? 'has cover' : 'no cover'} · {release.slug}</small>
          </a>
        );
      })}
    </div>
  </section>

  <section id="featured" class="section card review-section" data-review-section>
    <div class="section-head"><div><p class="eyebrow">Featured candidates</p><h2>Potential highlights</h2></div><span>{featuredCandidates.length} entries</span></div>
    {featuredCandidates.length > 0 ? <div class="review-list">{featuredCandidates.map((release) => { const cover = resolveMusicCover(release, import.meta.env.BASE_URL); const data = rowData(release, ['featured', release.source?.label === 'Manual catalogue' ? 'manual' : 'generated', release.platforms.length === 0 ? 'no-links' : 'has-links', cover.hasCover ? 'has-cover' : 'cover-missing', `cover-${cover.strategy}`]); return <a class="review-row" data-review-row data-search={data.search} data-tags={data.tags} data-cover-primary={cover.primary ?? ''} data-cover-fallback={cover.fallback ?? ''} href={withBase(`/music/${release.slug}/`)}><b>{release.title}</b><small>{release.releaseDate} · {release.source?.label ?? 'Generated'} · {release.platforms.length} links · {cover.strategy} · {release.slug}</small></a>; })}</div> : <p class="empty">No featured candidates yet.</p>}
  </section>

  <section id="no-public-links" class="section card review-section" data-review-section>
    <div class="section-head"><div><p class="eyebrow">No public links</p><h2>Entries missing platform URLs</h2></div><span>{noPublicLinks.length} entries</span></div>
    <p class="hint">Showing up to {sectionLimit} entries. Add public track URLs through <code>manualMusicQuality.ts</code> or <code>musicOverrides.ts</code>.</p>
    <div class="review-list">{noPublicLinks.slice(0, sectionLimit).map((release) => { const cover = resolveMusicCover(release, import.meta.env.BASE_URL); const data = rowData(release, ['no-links', release.source?.label === 'Manual catalogue' ? 'manual' : 'generated', release.featuredCandidate ? 'featured' : '', release.needsReview ? 'needs-review' : '', cover.hasCover ? 'has-cover' : 'cover-missing', `cover-${cover.strategy}`]); return <a class="review-row" data-review-row data-search={data.search} data-tags={data.tags} data-cover-primary={cover.primary ?? ''} data-cover-fallback={cover.fallback ?? ''} href={withBase(`/music/${release.slug}/`)}><b>{release.title}</b><small>{release.releaseDate} · {release.source?.label ?? 'Generated'} · {cover.strategy} · {release.slug}</small></a>; })}</div>
  </section>

  <section id="needs-review" class="section card review-section" data-review-section>
    <div class="section-head"><div><p class="eyebrow">Needs review</p><h2>Manual curation queue</h2></div><span>{needsReview.length} entries</span></div>
    {needsReview.length > 0 ? <div class="review-list">{needsReview.map((release) => { const cover = resolveMusicCover(release, import.meta.env.BASE_URL); const data = rowData(release, ['needs-review', release.source?.label === 'Manual catalogue' ? 'manual' : 'generated', release.platforms.length === 0 ? 'no-links' : 'has-links', cover.hasCover ? 'has-cover' : 'cover-missing', `cover-${cover.strategy}`]); return <a class="review-row" data-review-row data-search={data.search} data-tags={data.tags} data-cover-primary={cover.primary ?? ''} data-cover-fallback={cover.fallback ?? ''} href={withBase(`/music/${release.slug}/`)}><b>{release.title}</b><small>{release.releaseDate} · {release.source?.label ?? 'Generated'} · {cover.strategy} · {release.slug}</small></a>; })}</div> : <p class="empty">No entries are marked as needsReview.</p>}
  </section>

  <section id="duplicates" class="section card review-section" data-review-section>
    <div class="section-head"><div><p class="eyebrow">Possible duplicates</p><h2>Normalized title groups</h2></div><span>{duplicateGroups.length} groups</span></div>
    {duplicateGroups.length > 0 ? <div class="duplicate-list">{duplicateGroups.map((group) => <article class="duplicate-group"><h3>{normalizeDuplicateKey(group[0].title)} <span>{group.length} entries</span></h3><div class="review-list">{group.map((release) => { const cover = resolveMusicCover(release, import.meta.env.BASE_URL); const data = rowData(release, ['duplicate', release.source?.label === 'Manual catalogue' ? 'manual' : 'generated', release.platforms.length === 0 ? 'no-links' : 'has-links', cover.hasCover ? 'has-cover' : 'cover-missing', `cover-${cover.strategy}`]); return <a class="review-row" data-review-row data-search={data.search} data-tags={data.tags} data-cover-primary={cover.primary ?? ''} data-cover-fallback={cover.fallback ?? ''} href={withBase(`/music/${release.slug}/`)}><b>{release.title}</b><small>{release.releaseDate} · {release.source?.label ?? 'Generated'} · {cover.strategy} · {release.slug}</small></a>; })}</div></article>)}</div> : <p class="empty">No possible duplicate title groups found.</p>}
  </section>

  <section id="manual" class="section card review-section" data-review-section>
    <div class="section-head"><div><p class="eyebrow">Manual catalogue</p><h2>YTM-derived entries</h2></div><span>{manualEntries.length} entries</span></div>
    <p class="hint">Showing up to {sectionLimit} entries. Private playlist URLs are not stored or displayed.</p>
    <div class="review-list">{manualEntries.slice(0, sectionLimit).map((release) => { const cover = resolveMusicCover(release, import.meta.env.BASE_URL); const data = rowData(release, ['manual', release.platforms.length === 0 ? 'no-links' : 'has-links', release.featuredCandidate ? 'featured' : '', release.needsReview ? 'needs-review' : '', cover.hasCover ? 'has-cover' : 'cover-missing', `cover-${cover.strategy}`]); return <a class="review-row" data-review-row data-search={data.search} data-tags={data.tags} data-cover-primary={cover.primary ?? ''} data-cover-fallback={cover.fallback ?? ''} href={withBase(`/music/${release.slug}/`)}><b>{release.title}</b><small>{release.releaseDate} · {release.platforms.length} public links · {cover.strategy} · {release.slug}</small></a>; })}</div>
  </section>

  <script is:inline>
    const searchInput = document.querySelector('[data-catalogue-search]');
    const rows = Array.from(document.querySelectorAll('[data-review-row]'));
    const buttons = Array.from(document.querySelectorAll('[data-filter]'));
    const status = document.querySelector('[data-filter-status]');
    let activeFilter = 'all';

    const getSlug = (row) => {
      const href = row.getAttribute('href') || '';
      const parts = href.split('/').filter(Boolean);
      const musicIndex = parts.lastIndexOf('music');
      return musicIndex >= 0 ? parts[musicIndex + 1] || '' : parts[parts.length - 1] || '';
    };

    const escapeTs = (value) => String(value).replace(/\\/g, '\\\\').replace(/'/g, "\\'");

    const buildTemplates = (row) => {
      const slug = getSlug(row);
      const title = row.querySelector('b')?.textContent?.trim() || slug;
      const hasNoLinks = (row.getAttribute('data-tags') || '').includes('no-links');
      const coverPrimary = row.getAttribute('data-cover-primary') || '';
      const qualityTemplate = `'${slug}': {\n  title: '${escapeTs(title)}',\n  needsReview: false,\n  qualityNotes: ['TODO: describe manual catalogue cleanup.']\n},`;
      const platformsTemplate = `'${slug}': {\n  platforms: [\n    { label: 'YouTube Music', href: 'PUBLIC_TRACK_URL_HERE' }\n  ],\n  qualityNotes: ['Added public platform link.']\n},`;
      const coverTemplate = `'${slug}': {\n  coverSquare: '${escapeTs(coverPrimary || 'PUBLIC_1_1_COVER_URL_HERE')}',\n  qualityNotes: ['Added square cover override.']\n},`;
      const overrideTemplate = `'${slug}': {\n  title: '${escapeTs(title)}',\n  ${hasNoLinks ? "platforms: [\n    { label: 'YouTube Music', href: 'PUBLIC_TRACK_URL_HERE' }\n  ],\n  " : ''}forceMain: false,\n  forceSecondary: false\n},`;
      return { slug, qualityTemplate, platformsTemplate, coverTemplate, overrideTemplate };
    };

    const copyText = async (value) => {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(value);
        return;
      }
      const textarea = document.createElement('textarea');
      textarea.value = value;
      textarea.setAttribute('readonly', '');
      textarea.style.position = 'fixed';
      textarea.style.opacity = '0';
      document.body.appendChild(textarea);
      textarea.select();
      document.execCommand('copy');
      textarea.remove();
    };

    rows.forEach((row) => {
      const templates = buildTemplates(row);
      const actions = document.createElement('span');
      actions.className = 'copy-actions';
      [['Slug', templates.slug], ['Quality', templates.qualityTemplate], ['Platforms', templates.platformsTemplate], ['Cover', templates.coverTemplate], ['Override', templates.overrideTemplate]].forEach(([label, value]) => {
        const button = document.createElement('button');
        button.type = 'button';
        button.textContent = label;
        button.className = 'copy-button';
        button.addEventListener('click', async (event) => {
          event.preventDefault();
          event.stopPropagation();
          await copyText(value);
          if (status) status.textContent = `Copied ${label} helper for ${templates.slug}.`;
        });
        actions.appendChild(button);
      });
      row.appendChild(actions);
    });

    const applyFilter = () => {
      const query = (searchInput?.value || '').trim().toLowerCase();
      let visible = 0;
      rows.forEach((row) => {
        const search = row.getAttribute('data-search') || '';
        const tags = row.getAttribute('data-tags') || '';
        const filterMatch = activeFilter === 'all' || tags.includes(activeFilter);
        const queryMatch = !query || search.includes(query);
        const show = filterMatch && queryMatch;
        row.toggleAttribute('hidden', !show);
        if (show) visible += 1;
      });
      buttons.forEach((button) => button.classList.toggle('active', button.getAttribute('data-filter') === activeFilter));
      if (status) status.textContent = `Showing ${visible} matching review rows.`;
    };

    searchInput?.addEventListener('input', applyFilter);
    buttons.forEach((button) => button.addEventListener('click', () => { activeFilter = button.getAttribute('data-filter') || 'all'; applyFilter(); }));
  </script>
</BaseLayout>
<style>
  :global(html) { scroll-padding-top: 120px; }
  .review-hero { display: grid; grid-template-columns: minmax(0, 1fr) minmax(240px, auto); gap: 28px; align-items: end; padding: clamp(28px, 6vw, 56px); }
  .hero-actions { display: grid; gap: 12px; }
  .review-tools { position: sticky; top: 12px; z-index: 5; display: grid; gap: 16px; padding: 16px; margin: 24px auto 0; width: min(100% - 40px, var(--max)); }
  .quick-links, .filter-buttons { display: flex; flex-wrap: wrap; gap: 8px; }
  .quick-links a, .filter-buttons button, .copy-button { border: 1px solid rgba(236,238,255,.13); border-radius: 999px; background: rgba(7,8,18,.62); color: var(--muted); padding: 9px 12px; font: inherit; font-size: .82rem; font-weight: 850; cursor: pointer; }
  .filter-buttons button.active { border-color: rgba(217,210,255,.5); color: var(--accent); }
  .copy-button { padding: 7px 9px; font-size: .7rem; letter-spacing: .08em; text-transform: uppercase; }
  .copy-button:hover, .copy-button:focus-visible { border-color: rgba(217,210,255,.45); color: var(--accent); }
  .filter-bar { display: grid; gap: 12px; }
  .filter-bar label { display: grid; gap: 8px; }
  .filter-bar label span { color: var(--soft); font-size: .72rem; font-weight: 850; letter-spacing: .14em; text-transform: uppercase; }
  .filter-bar input { width: 100%; border: 1px solid rgba(236,238,255,.14); border-radius: 16px; background: rgba(7,8,18,.58); color: var(--text); padding: 13px 14px; font: inherit; }
  .filter-status { margin: 0; color: var(--soft); font-size: .86rem; }
  .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: 14px; }
  .stat-card { display: grid; gap: 12px; padding: 20px; }
  .stat-card span, .section-head > span { color: var(--soft); font-size: 0.72rem; font-weight: 850; letter-spacing: 0.14em; text-transform: uppercase; }
  .stat-card strong { color: var(--accent); font-size: 2rem; line-height: 1; }
  .review-section { padding: clamp(24px, 5vw, 38px); }
  .section-head { display: flex; justify-content: space-between; align-items: end; gap: 20px; margin-bottom: 22px; }
  .section-head h2 { margin: 0; font-size: clamp(1.8rem, 4.5vw, 3.2rem); line-height: 0.96; letter-spacing: -0.06em; }
  .section-head > span, .duplicate-group h3 span { border: 1px solid rgba(236,238,255,.13); border-radius: 999px; background: rgba(7,8,18,.52); padding: 8px 12px; white-space: nowrap; }
  .hint, .empty { color: var(--muted); line-height: 1.7; }
  code { border: 1px solid rgba(236,238,255,.13); border-radius: 8px; background: rgba(7,8,18,.52); padding: 2px 6px; }
  .review-list, .duplicate-list { display: grid; gap: 10px; }
  .review-row, .duplicate-group { border: 1px solid rgba(236,238,255,.12); border-radius: 18px; background: rgba(7,8,18,.48); }
  .review-row { display: grid; grid-template-columns: minmax(0, 1fr) minmax(220px, auto) auto; align-items: center; gap: 14px; padding: 14px 16px; transition: transform 160ms ease, border-color 160ms ease, background 160ms ease; }
  .review-row:hover, .review-row:focus-visible { transform: translateY(-2px); border-color: rgba(217,210,255,.45); background: rgba(19,22,42,.72); }
  .review-row[hidden] { display: none; }
  .review-row small { color: var(--soft); text-align: right; }
  .copy-actions { display: flex; flex-wrap: wrap; justify-content: flex-end; gap: 6px; }
  .duplicate-group { padding: 16px; }
  .duplicate-group h3 { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin: 0 0 12px; color: var(--accent); font-size: 1.2rem; }
  @media (max-width: 920px) { .review-row { grid-template-columns: 1fr; align-items: flex-start; } .review-row small { text-align: left; } .copy-actions { justify-content: flex-start; } }
  @media (max-width: 820px) { .review-hero, .section-head, .duplicate-group h3 { grid-template-columns: 1fr; flex-direction: column; align-items: flex-start; } .review-tools { width: min(100% - 28px, var(--max)); position: static; } }
</style>
