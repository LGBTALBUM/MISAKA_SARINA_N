---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { musicReleases } from '../../data/music';
import type { MusicRelease } from '../../data/music';

export function getStaticPaths() {
  return musicReleases.map((release) => ({
    params: { slug: release.slug },
    props: { release }
  }));
}

const { release } = Astro.props as { release: MusicRelease };
const withBase = (path: string) => {
  const base = import.meta.env.BASE_URL.endsWith('/')
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  return `${base}${path.replace(/^\/+/, '')}`;
};

const resolveAssetUrl = (url: string) => {
  if (/^https?:\/\//i.test(url)) return url;
  return withBase(url);
};
---

<BaseLayout title={release.title} description={release.description}>
  <section class="section release-hero card">
    <div class="cover" aria-hidden="true">
      {release.cover ? <img src={resolveAssetUrl(release.cover)} alt="" /> : <span>MS</span>}
    </div>
    <div>
      <p class="eyebrow">{release.type} · {release.releaseDate}</p>
      <h1 class="title">{release.title}</h1>
      <p class="copy">{release.description}</p>
      <div class="button-row">
        {release.platforms.map((platform) => (
          <a class="button" href={platform.href} target="_blank" rel="noreferrer">{platform.label}</a>
        ))}
      </div>
    </div>
  </section>

  {release.credits && release.credits.length > 0 && (
    <section class="section card page-card">
      <p class="eyebrow">Credits</p>
      <ul>
        {release.credits.map((credit) => <li>{credit}</li>)}
      </ul>
    </section>
  )}

  {release.notes && release.notes.length > 0 && (
    <section class="section card page-card">
      <p class="eyebrow">Notes</p>
      <ul>
        {release.notes.map((note) => <li>{note}</li>)}
      </ul>
    </section>
  )}

  <section class="section">
    <a class="button primary" href={withBase('/music')}>Back to music</a>
  </section>
</BaseLayout>

<style>
  .release-hero {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: 28px;
    align-items: center;
    padding: clamp(24px, 5vw, 42px);
  }

  .cover {
    display: grid;
    place-items: center;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: 28px;
    background: radial-gradient(circle at 35% 25%, #fff7fb, #ff7ac8 58%, #8d4cff);
  }

  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cover span {
    color: #190d15;
    font-size: 4rem;
    font-weight: 950;
    letter-spacing: -0.12em;
  }

  .page-card {
    padding: clamp(24px, 5vw, 42px);
  }

  ul {
    margin: 0;
    padding-left: 1.2rem;
    color: var(--muted);
    line-height: 1.8;
  }

  @media (max-width: 760px) {
    .release-hero {
      grid-template-columns: 1fr;
    }
  }
</style>
