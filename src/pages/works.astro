---
import BaseLayout from '../layouts/BaseLayout.astro';
import { works } from '../data/works';

const withBase = (path: string) => {
  const base = import.meta.env.BASE_URL.endsWith('/')
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  return `${base}${path.replace(/^\/+/, '')}`;
};

const statusLabel = {
  live: 'Live',
  reserved: 'Reserved',
  draft: 'Draft',
  maintained: 'Maintained'
};
---
<BaseLayout title="Works" description="Project and experiment catalogue for Misaka Sarina digital traces.">
  <section class="section card works-hero">
    <div>
      <p class="eyebrow">Works Archive</p>
      <h1 class="title">Projects, systems, and experiments.</h1>
      <p class="copy">A lightweight index for public-facing web tools, archive systems, music infrastructure, and technical experiments around the Misaka Sarina / Siacone Art space.</p>
    </div>
    <div class="stats" aria-label="Works archive stats">
      <div><span>Total</span><strong>{works.length}</strong></div>
      <div><span>Live</span><strong>{works.filter((work) => work.status === 'live').length}</strong></div>
      <div><span>Maintained</span><strong>{works.filter((work) => work.status === 'maintained').length}</strong></div>
    </div>
  </section>

  <section class="section works-list" aria-label="Works list">
    {works.map((work) => (
      <article class="card work-card">
        <div class="work-main">
          <p class="eyebrow">{work.category.replace('-', ' ')}</p>
          <h2>{work.title}</h2>
          <p>{work.summary}</p>
          <div class="tags">
            {work.tags.map((tag) => <span>{tag}</span>)}
          </div>
        </div>
        <div class="work-side">
          <strong>{statusLabel[work.status]}</strong>
          {work.href ? <a class="button" href={work.href.startsWith('/') ? withBase(work.href) : work.href}>Open</a> : <span class="muted">No public route yet</span>}
        </div>
      </article>
    ))}
  </section>

  <section class="section card next-card">
    <p class="eyebrow">Next step</p>
    <h2>Works can later grow into detail pages.</h2>
    <p class="copy">This page now has a static data foundation. The next expansion can add `/works/:slug/` detail pages, screenshots, repo links, changelogs, and deployment notes.</p>
    <div class="button-row">
      <a class="button primary" href={withBase('/blog')}>Read notes</a>
      <a class="button" href={withBase('/contact')}>Contact</a>
    </div>
  </section>
</BaseLayout>
<style>
  .works-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.42fr);
    gap: 28px;
    align-items: end;
    padding: clamp(28px, 6vw, 56px);
  }

  .stats {
    display: grid;
    gap: 12px;
  }

  .stats div,
  .work-card,
  .next-card {
    border: 1px solid rgba(236, 238, 255, 0.12);
  }

  .stats div {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    border-radius: 18px;
    background: rgba(7, 8, 18, 0.54);
    padding: 14px 16px;
  }

  .stats span,
  .tags span,
  .work-side .muted {
    color: var(--soft);
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .stats strong,
  .work-side strong {
    color: var(--accent);
  }

  .stats strong {
    font-size: 1.45rem;
    line-height: 1;
  }

  .works-list {
    display: grid;
    gap: 18px;
  }

  .work-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 180px;
    gap: 20px;
    padding: 24px;
  }

  .work-main h2,
  .next-card h2 {
    margin: 0 0 12px;
    font-size: clamp(1.7rem, 4vw, 2.7rem);
    line-height: 0.96;
    letter-spacing: -0.06em;
  }

  .work-main p {
    margin: 0;
    color: var(--muted);
    line-height: 1.72;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 16px;
  }

  .tags span {
    border: 1px solid rgba(236, 238, 255, 0.12);
    border-radius: 999px;
    background: rgba(7, 8, 18, 0.48);
    padding: 8px 10px;
  }

  .work-side {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-direction: column;
    gap: 14px;
  }

  .next-card {
    padding: clamp(28px, 6vw, 44px);
  }

  @media (max-width: 820px) {
    .works-hero,
    .work-card {
      grid-template-columns: 1fr;
    }

    .work-side {
      align-items: flex-start;
    }
  }
</style>
