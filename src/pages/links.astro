---
import BaseLayout from '../layouts/BaseLayout.astro';
import { linkGroups } from '../data/content';
---
<BaseLayout title="Links" description="All Misaka Sarina links grouped by listening platforms, social profiles, support, and projects.">
  <section class="section card links-hero">
    <p class="eyebrow" data-i18n="links.eyebrow">Links Archive</p>
    <h1 class="title" data-i18n="links.title">Everything in one place.</h1>
    <p class="copy" data-i18n="links.copy">The original Linkyee function is preserved here as a structured archive of listening platforms, social profiles, support channels, and project entrances.</p>
  </section>

  <section class="link-archive" aria-label="Link groups">
    {linkGroups.map((group) => (
      <section class="card group">
        <div class="group-head">
          <p class="eyebrow">{group.title}</p>
          <h2>{group.title}</h2>
          <span>{group.items.length} entries</span>
        </div>
        <div class="list">
          {group.items.map(([label, href, note]) => (
            <a class="link" href={href} target="_blank" rel="noreferrer">
              <b>{label}</b>
              <small>{note}</small>
            </a>
          ))}
        </div>
      </section>
    ))}
  </section>
</BaseLayout>
<style>
  .links-hero {
    padding: clamp(28px, 6vw, 56px);
  }

  .link-archive {
    display: grid;
    gap: 22px;
    margin: 0 0 88px;
  }

  .group {
    display: grid;
    grid-template-columns: 260px minmax(0, 1fr);
    gap: 24px;
    padding: clamp(22px, 4vw, 34px);
  }

  .group-head h2 {
    margin: 0 0 14px;
    font-size: clamp(1.7rem, 4vw, 2.7rem);
    line-height: 0.95;
    letter-spacing: -0.06em;
  }

  .group-head span {
    display: inline-flex;
    border: 1px solid rgba(236, 238, 255, 0.12);
    border-radius: 999px;
    color: var(--accent);
    background: rgba(7, 8, 18, 0.54);
    padding: 8px 12px;
    font-size: 0.78rem;
    font-weight: 850;
  }

  .list {
    display: grid;
    gap: 12px;
  }

  .link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    border: 1px solid rgba(236, 238, 255, 0.12);
    border-radius: 18px;
    background: rgba(7, 8, 18, 0.48);
    padding: 16px 18px;
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
  }

  .link:hover,
  .link:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(217, 210, 255, 0.45);
    background: rgba(19, 22, 42, 0.72);
  }

  .link b {
    color: var(--text);
  }

  .link small {
    color: var(--soft);
    text-align: right;
  }

  @media (max-width: 820px) {
    .group {
      grid-template-columns: 1fr;
    }

    .link {
      align-items: flex-start;
      flex-direction: column;
    }

    .link small {
      text-align: left;
    }
  }
</style>
