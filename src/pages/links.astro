---
import BaseLayout from '../layouts/BaseLayout.astro';
import { linkGroups } from '../data/content';
---
<BaseLayout title="Links" description="All Misaka Sarina links grouped by listening platforms, social profiles, support, and projects.">
  <section class="section">
    <p class="eyebrow">Links</p>
    <h1 class="title">Everything in one place.</h1>
    <p class="copy">The original Linkyee function is preserved here, but grouped for easier scanning.</p>
  </section>
  {linkGroups.map((group) => <section class="section group"><div><p class="eyebrow">{group.title}</p><h2>{group.title}</h2></div><div class="list">{group.items.map(([label, href, note]) => <a class="card link" href={href} target="_blank" rel="noreferrer"><b>{label}</b><small>{note}</small></a>)}</div></section>)}
</BaseLayout>
<style>.group{display:grid;grid-template-columns:280px 1fr;gap:24px}.group h2{margin:0;font-size:2.2rem;letter-spacing:-.05em}.list{display:grid;gap:12px}.link{display:flex;justify-content:space-between;gap:16px;padding:18px 20px}.link small{color:var(--muted);text-align:right}@media(max-width:820px){.group{grid-template-columns:1fr}.link{flex-direction:column}.link small{text-align:left}}</style>
