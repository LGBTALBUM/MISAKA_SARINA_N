---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { works } from '../../data/works';
import type { WorkItem } from '../../data/works';

export function getStaticPaths() {
  return works.map((work) => ({
    params: { slug: work.slug },
    props: { work }
  }));
}

const { work } = Astro.props as { work: WorkItem };
const withBase = (path: string) => {
  const base = import.meta.env.BASE_URL.endsWith('/')
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  return `${base}${path.replace(/^\/+/, '')}`;
};
const resolveHref = (href: string) => href.startsWith('/') ? withBase(href) : href;

const statusLabel = {
  live: 'Live',
  reserved: 'Reserved',
  draft: 'Draft',
  maintained: 'Maintained'
};
---
<BaseLayout title={work.title} description={work.summary}>
  <section class="section card detail-hero">
    <div>
      <p class="eyebrow">{work.category.replace('-', ' ')}</p>
      <h1 class="title">{work.title}</h1>
      <p class="copy">{work.summary}</p>
    </div>
    <div class="meta-panel">
      <div><span>Status</span><strong>{statusLabel[work.status]}</strong></div>
      <div><span>Category</span><strong>{work.category}</strong></div>
      <div><span>Slug</span><strong>{work.slug}</strong></div>
    </div>
  </section>

  <section class="section detail-grid">
    <section class="card page-card">
      <p class="eyebrow">Tags</p>
      <div class="tags">
        {work.tags.map((tag) => <span>{tag}</span>)}
      </div>
    </section>

    <section class="card page-card content-card">
      <p class="eyebrow">Overview</p>
      {(work.bodySections ?? []).map((section) => (
        <article class="content-section">
          <h2>{section.title}</h2>
          <p>{section.body}</p>
        </article>
      ))}
    </section>

    {work.serviceEndpoints && work.serviceEndpoints.length > 0 && (
      <section class="card page-card service-card">
        <p class="eyebrow">Service endpoints</p>
        <div class="endpoint-list">
          {work.serviceEndpoints.map((endpoint) => (
            <article class="endpoint-card">
              <div>
                <span>{endpoint.protocol}</span>
                <h2>{endpoint.label}</h2>
                {endpoint.note && <p>{endpoint.note}</p>}
              </div>
              <button
                class="copy-endpoint"
                type="button"
                data-copy-value={endpoint.value}
                data-copy-default="Copy endpoint"
                data-copy-done="Copied"
                data-copy-error="Copy failed"
                aria-label={`Copy ${endpoint.value}`}
              >
                <code>{endpoint.value}</code>
                <small>Copy</small>
              </button>
            </article>
          ))}
        </div>
      </section>
    )}

    {work.links && work.links.length > 0 && (
      <section class="card page-card">
        <p class="eyebrow">Links</p>
        <div class="link-list">
          {work.links.map((link) => (
            <a href={resolveHref(link.href)} target={link.href.startsWith('/') ? undefined : '_blank'} rel={link.href.startsWith('/') ? undefined : 'noreferrer'}>
              <strong>{link.label}</strong>
              {link.note && <small>{link.note}</small>}
            </a>
          ))}
        </div>
      </section>
    )}

    {work.changelog && work.changelog.length > 0 && (
      <section class="card page-card content-card">
        <p class="eyebrow">Changelog</p>
        {work.changelog.map((entry) => (
          <article class="content-section">
            <time datetime={entry.date}>{entry.date}</time>
            <h2>{entry.title}</h2>
            <p>{entry.body}</p>
          </article>
        ))}
      </section>
    )}

    {work.related && work.related.length > 0 && (
      <section class="card page-card related-card">
        <p class="eyebrow">Related</p>
        <div class="link-list">
          {work.related.map((link) => (
            <a href={resolveHref(link.href)} target={link.href.startsWith('/') ? undefined : '_blank'} rel={link.href.startsWith('/') ? undefined : 'noreferrer'}>
              <strong>{link.label}</strong>
              {link.note && <small>{link.note}</small>}
            </a>
          ))}
        </div>
      </section>
    )}
  </section>

  <section class="section button-row back-row">
    {work.href && <a class="button primary" href={resolveHref(work.href)}>Open work</a>}
    <a class="button" href={withBase('/works')}>Back to works</a>
    <a class="button" href={withBase('/blog')}>Read notes</a>
  </section>
</BaseLayout>
<style>
  .detail-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.42fr);
    gap: 28px;
    align-items: end;
    padding: clamp(28px, 6vw, 56px);
  }

  .meta-panel {
    display: grid;
    gap: 12px;
  }

  .meta-panel div,
  .page-card {
    border: 1px solid rgba(236, 238, 255, 0.12);
    border-radius: 18px;
    background: rgba(7, 8, 18, 0.54);
  }

  .meta-panel div {
    display: grid;
    gap: 6px;
    padding: 14px 16px;
  }

  .meta-panel span,
  .tags span,
  .content-section time,
  .endpoint-card span,
  .copy-endpoint small {
    color: var(--soft);
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .meta-panel strong {
    color: var(--accent);
    word-break: break-word;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: minmax(260px, 0.5fr) minmax(0, 1fr);
    gap: 18px;
  }

  .page-card {
    padding: clamp(22px, 4vw, 34px);
  }

  .content-card,
  .service-card,
  .related-card {
    grid-column: 1 / -1;
  }

  .content-section + .content-section {
    margin-top: 26px;
    padding-top: 22px;
    border-top: 1px solid rgba(236, 238, 255, 0.1);
  }

  .content-section h2 {
    margin: 0 0 12px;
    font-size: clamp(1.55rem, 4vw, 2.4rem);
    line-height: 1;
    letter-spacing: -0.06em;
  }

  .content-section p {
    margin: 0;
    color: var(--muted);
    line-height: 1.8;
  }

  .tags,
  .link-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tags span {
    border: 1px solid rgba(236, 238, 255, 0.12);
    border-radius: 999px;
    background: rgba(7, 8, 18, 0.48);
    padding: 8px 10px;
  }

  .link-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 12px;
  }

  .link-list a,
  .endpoint-card,
  .copy-endpoint {
    border: 1px solid rgba(236, 238, 255, 0.12);
    border-radius: 16px;
    background: rgba(7, 8, 18, 0.48);
  }

  .link-list a {
    display: grid;
    gap: 6px;
    padding: 14px;
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
  }

  .link-list a:hover,
  .link-list a:focus-visible,
  .copy-endpoint:hover,
  .copy-endpoint:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(217, 210, 255, 0.45);
    background: rgba(19, 22, 42, 0.72);
  }

  .link-list small {
    color: var(--soft);
  }

  .endpoint-list {
    display: grid;
    gap: 12px;
  }

  .endpoint-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(220px, auto);
    gap: 18px;
    align-items: center;
    padding: clamp(18px, 3vw, 24px);
  }

  .endpoint-card h2 {
    margin: 8px 0 10px;
    font-size: clamp(1.45rem, 4vw, 2.35rem);
    line-height: 1;
    letter-spacing: -0.06em;
  }

  .endpoint-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.65;
  }

  .copy-endpoint {
    display: grid;
    gap: 8px;
    justify-items: start;
    color: var(--text);
    cursor: pointer;
    padding: 14px 16px;
    text-align: left;
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
  }

  .copy-endpoint code {
    font: inherit;
    font-size: clamp(1rem, 2vw, 1.35rem);
    font-weight: 900;
    letter-spacing: -0.025em;
    word-break: break-all;
  }

  .copy-endpoint[data-copied="true"] {
    border-color: rgba(168, 184, 255, 0.42);
  }

  .back-row {
    margin-top: 36px;
  }

  @media (max-width: 820px) {
    .detail-hero,
    .detail-grid,
    .endpoint-card {
      grid-template-columns: 1fr;
    }
  }
</style>
