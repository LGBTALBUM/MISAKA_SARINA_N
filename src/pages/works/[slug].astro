---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { works } from '../../data/works';
import type { WorkItem } from '../../data/works';

export function getStaticPaths() {
  return works.map((work) => ({
    params: { slug: work.slug },
    props: { work }
  }));
}

const { work } = Astro.props as { work: WorkItem };
const withBase = (path: string) => {
  const base = import.meta.env.BASE_URL.endsWith('/')
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  return `${base}${path.replace(/^\/+/, '')}`;
};

const statusLabel = {
  live: 'Live',
  reserved: 'Reserved',
  draft: 'Draft',
  maintained: 'Maintained'
};
---
<BaseLayout title={work.title} description={work.summary}>
  <section class="section card detail-hero">
    <div>
      <p class="eyebrow">{work.category.replace('-', ' ')}</p>
      <h1 class="title">{work.title}</h1>
      <p class="copy">{work.summary}</p>
    </div>
    <div class="meta-panel">
      <div><span>Status</span><strong>{statusLabel[work.status]}</strong></div>
      <div><span>Category</span><strong>{work.category}</strong></div>
      <div><span>Slug</span><strong>{work.slug}</strong></div>
    </div>
  </section>

  <section class="section detail-grid">
    <section class="card page-card">
      <p class="eyebrow">Tags</p>
      <div class="tags">
        {work.tags.map((tag) => <span>{tag}</span>)}
      </div>
    </section>

    <section class="card page-card">
      <p class="eyebrow">Entry notes</p>
      <p class="copy">This work entry is generated from lightweight static data. It can later grow into a richer project page with screenshots, changelog, repository links, deployment notes, and maintenance history.</p>
    </section>
  </section>

  <section class="section button-row back-row">
    {work.href && <a class="button primary" href={work.href.startsWith('/') ? withBase(work.href) : work.href}>Open work</a>}
    <a class="button" href={withBase('/works')}>Back to works</a>
    <a class="button" href={withBase('/blog')}>Read notes</a>
  </section>
</BaseLayout>
<style>
  .detail-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.42fr);
    gap: 28px;
    align-items: end;
    padding: clamp(28px, 6vw, 56px);
  }

  .meta-panel {
    display: grid;
    gap: 12px;
  }

  .meta-panel div,
  .page-card {
    border: 1px solid rgba(236, 238, 255, 0.12);
    border-radius: 18px;
    background: rgba(7, 8, 18, 0.54);
  }

  .meta-panel div {
    display: grid;
    gap: 6px;
    padding: 14px 16px;
  }

  .meta-panel span,
  .tags span {
    color: var(--soft);
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .meta-panel strong {
    color: var(--accent);
    word-break: break-word;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: minmax(260px, 0.5fr) minmax(0, 1fr);
    gap: 18px;
  }

  .page-card {
    padding: clamp(22px, 4vw, 34px);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tags span {
    border: 1px solid rgba(236, 238, 255, 0.12);
    border-radius: 999px;
    background: rgba(7, 8, 18, 0.48);
    padding: 8px 10px;
  }

  .back-row {
    margin-top: 36px;
  }

  @media (max-width: 820px) {
    .detail-hero,
    .detail-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
