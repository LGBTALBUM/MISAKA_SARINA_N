---
import BaseLayout from '../layouts/BaseLayout.astro';
import { posts } from '../data/posts';

const withBase = (path: string) => {
  const base = import.meta.env.BASE_URL.endsWith('/')
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  return `${base}${path.replace(/^\/+/, '')}`;
};

const statusLabel = {
  planned: 'Planned',
  draft: 'Draft',
  published: 'Published'
};
---
<BaseLayout title="Blog" description="Notes, release diaries, and digital garden index.">
  <section class="section card blog-hero">
    <div>
      <p class="eyebrow" data-i18n="blog.archive">Digital Garden</p>
      <h1 class="title" data-i18n="blog.title">Notes, diaries, and maintenance logs.</h1>
      <p class="copy" data-i18n="blog.copy">A prepared writing surface for release context, technical notes, production logs, and reproducible site maintenance records.</p>
    </div>
    <div class="stats" aria-label="Blog archive stats">
      <div><span>Total</span><strong>{posts.length}</strong></div>
      <div><span>Draft</span><strong>{posts.filter((post) => post.status === 'draft').length}</strong></div>
      <div><span>Planned</span><strong>{posts.filter((post) => post.status === 'planned').length}</strong></div>
    </div>
  </section>

  <section class="section posts-list" aria-label="Notes list">
    {posts.map((post) => (
      <article class="card post-card">
        <div class="post-main">
          <p class="eyebrow">{post.category.replace('-', ' ')}</p>
          <h2>{post.title}</h2>
          <p>{post.summary}</p>
          <div class="tags">
            {post.tags.map((tag) => <span>{tag}</span>)}
          </div>
        </div>
        <div class="post-side">
          <time datetime={post.date}>{post.date}</time>
          <strong>{statusLabel[post.status]}</strong>
          <a class="button primary" href={withBase(`/blog/${post.slug}/`)} data-i18n="blog.details">Details</a>
        </div>
      </article>
    ))}
  </section>

  <section class="section card next-card">
    <p class="eyebrow" data-i18n="blog.next">Next step</p>
    <h2 data-i18n="blog.nextTitle">Blog entries now have shareable detail pages.</h2>
    <p class="copy" data-i18n="blog.nextCopy">The current page uses lightweight static data. Later, this can become MDX-powered posts with full body content, references, tags, excerpts, and RSS without changing the first-level information architecture.</p>
    <div class="button-row">
      <a class="button primary" href={withBase('/works')} data-i18n="blog.viewWorks">View works</a>
      <a class="button" href={withBase('/music')} data-i18n="blog.musicArchive">Music archive</a>
    </div>
  </section>
</BaseLayout>
<style>
  .blog-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.42fr);
    gap: 28px;
    align-items: end;
    padding: clamp(28px, 6vw, 56px);
  }

  .stats {
    display: grid;
    gap: 12px;
  }

  .stats div,
  .post-card,
  .next-card {
    border: 1px solid rgba(236, 238, 255, 0.12);
  }

  .stats div {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    border-radius: 18px;
    background: rgba(7, 8, 18, 0.54);
    padding: 14px 16px;
  }

  .stats span,
  .tags span,
  .post-side time {
    color: var(--soft);
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .stats strong,
  .post-side strong {
    color: var(--accent);
  }

  .stats strong {
    font-size: 1.45rem;
    line-height: 1;
  }

  .posts-list {
    display: grid;
    gap: 18px;
  }

  .post-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 160px;
    gap: 20px;
    padding: 24px;
  }

  .post-main h2,
  .next-card h2 {
    margin: 0 0 12px;
    font-size: clamp(1.7rem, 4vw, 2.7rem);
    line-height: 0.96;
    letter-spacing: -0.06em;
  }

  .post-main p {
    margin: 0;
    color: var(--muted);
    line-height: 1.72;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 16px;
  }

  .tags span {
    border: 1px solid rgba(236, 238, 255, 0.12);
    border-radius: 999px;
    background: rgba(7, 8, 18, 0.48);
    padding: 8px 10px;
  }

  .post-side {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-direction: column;
    gap: 14px;
  }

  .next-card {
    padding: clamp(28px, 6vw, 44px);
  }

  @media (max-width: 820px) {
    .blog-hero,
    .post-card {
      grid-template-columns: 1fr;
    }

    .post-side {
      align-items: flex-start;
    }
  }
</style>
