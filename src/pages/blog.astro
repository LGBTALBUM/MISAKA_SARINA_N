---
import BaseLayout from '../layouts/BaseLayout.astro';
const withBase = (path: string) => {
  const base = import.meta.env.BASE_URL.endsWith('/')
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  return `${base}${path.replace(/^\/+/, '')}`;
};
---
<BaseLayout title="Blog" description="Notes and digital garden placeholder."><section class="section card page-card"><p class="eyebrow">Blog</p><h1 class="title">Digital garden is reserved.</h1><p class="copy">Prepared for future technical notes, music production logs, release diaries, and infrastructure SOPs.</p><a class="button primary" href={withBase('/links')}>Back to links</a></section></BaseLayout><style>.page-card{padding:clamp(28px,6vw,56px)}</style>
