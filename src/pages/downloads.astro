---
import BaseLayout from '../layouts/BaseLayout.astro';

const downloadItems = [
  {
    titleKey: 'downloads.handwritingTitle',
    eyebrowKey: 'downloads.handwritingEyebrow',
    copyKey: 'downloads.handwritingCopy',
    href: 'https://github.com/LGBTALBUM/MisakaSarinaHandwritingOne',
    ctaKey: 'downloads.openRepository',
    fallbackEyebrow: 'Font',
    fallbackTitle: 'MisakaSarina Handwriting One — First Version',
    fallbackCopy: 'First version of the MisakaSarina handwriting font project.'
  },
  {
    titleKey: 'downloads.cjkExtTitle',
    eyebrowKey: 'downloads.cjkExtEyebrow',
    copyKey: 'downloads.cjkExtCopy',
    href: 'https://github.com/LGBTALBUM/MisakaHand-CJKExt-S100',
    ctaKey: 'downloads.openRepository',
    fallbackEyebrow: 'CJK font',
    fallbackTitle: 'MisakaHand CJK Extension S100',
    fallbackCopy: 'CJK extension font project for the MisakaHand series, distributed through its GitHub repository.'
  },
  {
    titleKey: 'downloads.risatTitle',
    eyebrowKey: 'downloads.risatEyebrow',
    copyKey: 'downloads.risatCopy',
    href: 'https://github.com/LGBTALBUM/RISAT',
    ctaKey: 'downloads.openRepository',
    fallbackEyebrow: 'Image audio transport',
    fallbackTitle: 'RISAT',
    fallbackCopy: 'RCA-Image Stereo Analog Transport converts an image into a stereo audio signal that can pass through two RCA cables or be recorded onto an analog audio medium, then reconstructs the image with channel correction and error recovery.'
  }
];

const downloadLanes = [
  {
    key: 'tools',
    titleKey: 'downloads.laneToolsTitle',
    eyebrowKey: 'downloads.laneToolsEyebrow',
    copyKey: 'downloads.laneToolsCopy'
  },
  {
    key: 'audio',
    titleKey: 'downloads.laneAudioTitle',
    eyebrowKey: 'downloads.laneAudioEyebrow',
    copyKey: 'downloads.laneAudioCopy'
  },
  {
    key: 'archive',
    titleKey: 'downloads.laneArchiveTitle',
    eyebrowKey: 'downloads.laneArchiveEyebrow',
    copyKey: 'downloads.laneArchiveCopy'
  }
];
---

<BaseLayout title="Downloads" description="Download area for Misaka Sarina small tools, archive packages, and creator-made utilities.">
  <section class="section card downloads-hero">
    <div>
      <p class="eyebrow" data-i18n="downloads.eyebrow">Downloads</p>
      <h1 class="title" data-i18n="downloads.title">A small shelf for downloadable works.</h1>
      <p class="copy" data-i18n="downloads.copy">This area collects small tools, archive packages, music-related files, and creator-made utilities that are ready to share.</p>
    </div>
    <div class="stats" aria-label="Downloads status">
      <div><span data-i18n="downloads.status">Status</span><strong data-i18n="downloads.statusValue">Available</strong></div>
      <div><span data-i18n="downloads.items">Items</span><strong>{downloadItems.length}</strong></div>
      <div><span data-i18n="downloads.format">Format</span><strong data-i18n="downloads.formatValue">Mixed</strong></div>
    </div>
  </section>

  <section class="section downloads-list" aria-label="Available downloads">
    {downloadItems.map((item) => (
      <article class="card download-card featured-download">
        <div>
          <p class="eyebrow" data-i18n={item.eyebrowKey}>{item.fallbackEyebrow}</p>
          <h2 data-i18n={item.titleKey}>{item.fallbackTitle}</h2>
          <p data-i18n={item.copyKey}>{item.fallbackCopy}</p>
        </div>
        <div class="download-actions">
          <span class="status-pill" data-i18n="downloads.available">Available</span>
          <a class="button primary" href={item.href} target="_blank" rel="noreferrer" data-i18n={item.ctaKey}>Open repository</a>
        </div>
      </article>
    ))}
  </section>

  <section class="section downloads-list" aria-label="Download lanes">
    {downloadLanes.map((lane) => (
      <article class="card download-card">
        <div>
          <p class="eyebrow" data-i18n={lane.eyebrowKey}>Download lane</p>
          <h2 data-i18n={lane.titleKey}>Download category</h2>
          <p data-i18n={lane.copyKey}>This lane describes a download category and will collect matching items as they become available.</p>
        </div>
        <span class="status-pill" data-i18n="downloads.categoryLane">Category lane</span>
      </article>
    ))}
  </section>

  <section class="section card downloads-note">
    <p class="eyebrow" data-i18n="downloads.submitNote">Distribution note</p>
    <h2 data-i18n="downloads.noteTitle">Files stay versioned and reviewable.</h2>
    <p class="copy" data-i18n="downloads.noteCopy">Downloadable items should keep clear names, version notes, and a short explanation of what each file is for.</p>
    <div class="button-row">
      <a class="button primary" href="/works/" data-i18n="downloads.viewWorks">View works</a>
      <a class="button" href="/contact/" data-i18n="downloads.contact">Contact</a>
    </div>
  </section>
</BaseLayout>

<style>
  .downloads-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.42fr);
    gap: 28px;
    align-items: end;
    padding: clamp(28px, 6vw, 56px);
  }

  .stats {
    display: grid;
    gap: 12px;
  }

  .stats div {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    border: 1px solid rgba(236, 238, 255, 0.12);
    border-radius: 18px;
    background: rgba(7, 8, 18, 0.54);
    padding: 14px 16px;
  }

  .stats span,
  .status-pill {
    color: var(--soft);
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .stats strong {
    color: var(--accent);
    font-size: 1.45rem;
    line-height: 1;
  }

  .downloads-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 18px;
  }

  .download-card {
    display: grid;
    gap: 24px;
    align-content: space-between;
    min-height: 260px;
    padding: clamp(22px, 4vw, 34px);
  }

  .featured-download {
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    min-height: 220px;
  }

  .download-card h2,
  .downloads-note h2 {
    margin: 0 0 12px;
    font-size: clamp(1.8rem, 4vw, 3rem);
    line-height: 0.96;
    letter-spacing: -0.06em;
  }

  .download-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.72;
  }

  .download-actions {
    display: grid;
    justify-items: end;
    gap: 12px;
  }

  .status-pill {
    width: max-content;
    border: 1px solid rgba(236, 238, 255, 0.12);
    border-radius: 999px;
    background: rgba(7, 8, 18, 0.48);
    padding: 9px 12px;
  }

  .downloads-note {
    padding: clamp(28px, 6vw, 44px);
  }

  @media (max-width: 820px) {
    .downloads-hero,
    .featured-download {
      grid-template-columns: 1fr;
    }

    .download-actions {
      justify-items: start;
    }
  }
</style>
