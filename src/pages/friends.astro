---
import BaseLayout from '../layouts/BaseLayout.astro';
import { friends } from '../data/friends';
---

<BaseLayout title="Friends" description="Friend links and neighboring sites around Misaka Sarina.">
  <section class="section friends-hero card">
    <div>
      <p class="eyebrow" data-i18n="friends.eyebrow">Friends</p>
      <h1 class="title" data-i18n="friends.title">Neighboring stars.</h1>
      <p class="copy" data-i18n="friends.copy">Friend links, personal sites, and neighboring spaces connected to the Misaka Sarina archive.</p>
    </div>
    <div class="friend-count" aria-label="Friend link count">
      <span data-i18n="friends.links">Links</span>
      <strong>{friends.length}</strong>
    </div>
  </section>

  <section class="section friend-grid" aria-label="Friend links">
    {friends.map((friend) => (
      <a class="card friend-card" href={friend.href} target="_blank" rel="noreferrer">
        <span data-i18n="friends.site">{friend.note ?? 'Friend site'}</span>
        <h2>{friend.name}</h2>
        <p>{friend.href.replace(/^https?:\/\//, '').replace(/\/$/, '')}</p>
      </a>
    ))}
  </section>
</BaseLayout>

<style>
  .friends-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(180px, 0.28fr);
    gap: clamp(24px, 5vw, 46px);
    align-items: end;
    padding: clamp(26px, 5vw, 46px);
  }

  .friend-count {
    display: grid;
    gap: 10px;
    border: 1px solid rgba(236, 238, 255, 0.12);
    border-radius: 20px;
    background: rgba(7, 8, 18, 0.54);
    padding: 18px;
  }

  .friend-count span,
  .friend-card span {
    color: var(--soft);
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .friend-count strong {
    color: var(--accent);
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1;
  }

  .friend-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .friend-card {
    display: grid;
    min-height: 220px;
    align-content: space-between;
    gap: 22px;
    padding: clamp(22px, 4vw, 30px);
    overflow: hidden;
    position: relative;
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
  }

  .friend-card::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    border-radius: inherit;
    background: radial-gradient(circle at 20% 0%, rgba(217, 210, 255, 0.14), transparent 42%);
    opacity: 0;
    transition: opacity 160ms ease;
  }

  .friend-card:hover,
  .friend-card:focus-visible {
    transform: translateY(-3px);
    border-color: rgba(217, 210, 255, 0.44);
    background: linear-gradient(145deg, rgba(12, 15, 34, 0.9), rgba(8, 10, 24, 0.62));
  }

  .friend-card:hover::after,
  .friend-card:focus-visible::after {
    opacity: 1;
  }

  .friend-card h2 {
    margin: 0;
    font-size: clamp(1.55rem, 3.8vw, 2.7rem);
    line-height: 0.96;
    letter-spacing: -0.07em;
  }

  .friend-card p {
    margin: 0;
    color: var(--muted);
    overflow-wrap: anywhere;
  }

  @media (max-width: 900px) {
    .friend-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .friends-hero,
    .friend-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
