---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Bluesky RSS" description="Worker JSON feed.">
  <link rel="stylesheet" href="/bsky-feed.css" />
  <section class="section card bsky-hero">
    <p class="eyebrow">Bluesky RSS</p>
    <h1 class="title">Short social stream.</h1>
    <p class="copy">Recent posts are loaded from the Worker JSON feed.</p>
    <p data-bluesky-status>Loading feed...</p>
    <div class="button-row">
      <a class="button primary" href="/api/bluesky-rss.json" target="_blank" rel="noreferrer">Open JSON</a>
      <a class="button" href="https://bsky.app/profile/msarina.bluesky.siacone.art" target="_blank" rel="noreferrer">Open Bluesky</a>
      <a class="button" href="/blog/">Back to blog</a>
    </div>
  </section>
  <section class="section bsky-list" data-bluesky-feed>
    <article class="bsky-card"><p>Loading recent posts...</p></article>
  </section>
  <script src="/bsky-feed.js?v=card-pr-1" defer></script>
</BaseLayout>
