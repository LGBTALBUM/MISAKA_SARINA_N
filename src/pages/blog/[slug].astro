---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { posts } from '../../data/posts';
import type { PostItem } from '../../data/posts';
import { blogPostJsonLd } from '../../utils/seo';

export function getStaticPaths() {
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props as { post: PostItem };
const withBase = (path: string) => {
  const base = import.meta.env.BASE_URL.endsWith('/')
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  return `${base}${path.replace(/^\/+/, '')}`;
};
const resolveHref = (href: string) => href.startsWith('/') ? withBase(href) : href;

const statusLabel = {
  planned: 'Planned',
  draft: 'Draft',
  published: 'Published'
};
---
<BaseLayout
  title={post.title}
  description={post.summary}
  ogType="article"
  publishedTime={post.date}
  modifiedTime={post.date}
  tags={post.tags}
  jsonLd={blogPostJsonLd(post)}
>
  <section class="section card detail-hero">
    <div>
      <p class="eyebrow">{post.category.replace('-', ' ')}</p>
      <h1 class="title">{post.title}</h1>
      <p class="copy">{post.summary}</p>
    </div>
    <div class="meta-panel">
      <div><span>Status</span><strong>{statusLabel[post.status]}</strong></div>
      <div><span>Date</span><strong>{post.date}</strong></div>
      <div><span>Slug</span><strong>{post.slug}</strong></div>
    </div>
  </section>

  <section class="section detail-grid">
    <section class="card page-card">
      <p class="eyebrow">Tags</p>
      <div class="tags">
        {post.tags.map((tag) => <span>{tag}</span>)}
      </div>
    </section>

    <section class="card page-card content-card">
      <p class="eyebrow">Body</p>
      {(post.bodySections ?? []).map((section) => (
        <article class="content-section">
          <h2>{section.title}</h2>
          <p>{section.body}</p>
        </article>
      ))}
    </section>

    {post.links && post.links.length > 0 && (
      <section class="card page-card">
        <p class="eyebrow">Links</p>
        <div class="link-list">
          {post.links.map((link) => (
            <a href={resolveHref(link.href)} target={link.href.startsWith('/') ? undefined : '_blank'} rel={link.href.startsWith('/') ? undefined : 'noreferrer'}>
              <strong>{link.label}</strong>
              {link.note && <small>{link.note}</small>}
            </a>
          ))}
        </div>
      </section>
    )}

    {post.related && post.related.length > 0 && (
      <section class="card page-card related-card">
        <p class="eyebrow">Related</p>
        <div class="link-list">
          {post.related.map((link) => (
            <a href={resolveHref(link.href)} target={link.href.startsWith('/') ? undefined : '_blank'} rel={link.href.startsWith('/') ? undefined : 'noreferrer'}>
              <strong>{link.label}</strong>
              {link.note && <small>{link.note}</small>}
            </a>
          ))}
        </div>
      </section>
    )}
  </section>

  <section class="section button-row back-row">
    <a class="button primary" href={withBase('/blog')}>Back to blog</a>
    <a class="button" href={withBase('/works')}>View works</a>
    <a class="button" href={withBase('/music')}>Music archive</a>
  </section>
</BaseLayout>
<style>
  .detail-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.42fr);
    gap: 28px;
    align-items: end;
    padding: clamp(28px, 6vw, 56px);
  }

  .meta-panel {
    display: grid;
    gap: 12px;
  }

  .meta-panel div,
  .page-card {
    border: 1px solid rgba(236, 238, 255, 0.12);
    border-radius: 18px;
    background: rgba(7, 8, 18, 0.54);
  }

  .meta-panel div {
    display: grid;
    gap: 6px;
    padding: 14px 16px;
  }

  .meta-panel span,
  .tags span {
    color: var(--soft);
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .meta-panel strong {
    color: var(--accent);
    word-break: break-word;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: minmax(260px, 0.5fr) minmax(0, 1fr);
    gap: 18px;
  }

  .page-card {
    padding: clamp(22px, 4vw, 34px);
  }

  .content-card,
  .related-card {
    grid-column: 1 / -1;
  }

  .content-section + .content-section {
    margin-top: 26px;
    padding-top: 22px;
    border-top: 1px solid rgba(236, 238, 255, 0.1);
  }

  .content-section h2 {
    margin: 0 0 12px;
    font-size: clamp(1.55rem, 4vw, 2.4rem);
    line-height: 1;
    letter-spacing: -0.06em;
  }

  .content-section p {
    margin: 0;
    color: var(--muted);
    line-height: 1.8;
  }

  .tags,
  .link-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tags span {
    border: 1px solid rgba(236, 238, 255, 0.12);
    border-radius: 999px;
    background: rgba(7, 8, 18, 0.48);
    padding: 8px 10px;
  }

  .link-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 12px;
  }

  .link-list a {
    display: grid;
    gap: 6px;
    border: 1px solid rgba(236, 238, 255, 0.12);
    border-radius: 16px;
    background: rgba(7, 8, 18, 0.48);
    padding: 14px;
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
  }

  .link-list a:hover,
  .link-list a:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(217, 210, 255, 0.45);
    background: rgba(19, 22, 42, 0.72);
  }

  .link-list small {
    color: var(--soft);
  }

  .back-row {
    margin-top: 36px;
  }

  @media (max-width: 820px) {
    .detail-hero,
    .detail-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
