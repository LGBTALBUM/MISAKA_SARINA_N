---
import type { MusicRelease } from '../data/music';

const { release } = Astro.props as { release: MusicRelease };
const isManualCatalogue = release.source?.label === 'Manual catalogue';
const withBase = (path: string) => {
  const base = import.meta.env.BASE_URL.endsWith('/')
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  return `${base}${path.replace(/^\/+/, '')}`;
};

const resolveAssetUrl = (url: string) => {
  if (/^https?:\/\//i.test(url)) return url;
  return withBase(url);
};
---

<a class="card music-card" href={withBase(`/music/${release.slug}/`)}>
  <div class="cover" aria-hidden="true">
    {release.cover ? <img src={resolveAssetUrl(release.cover)} alt="" /> : <span>MS</span>}
  </div>
  <div class="content">
    <p class="meta">{release.type.toUpperCase()} · {release.releaseDate}</p>
    <div class="title-row">
      <h2>{release.title}</h2>
      {isManualCatalogue && <span class="badge">Manual catalogue</span>}
    </div>
    <p>{release.description}</p>
    <span class="open">Open archive entry</span>
  </div>
</a>

<style>
  .music-card {
    display: grid;
    grid-template-columns: 148px minmax(0, 1fr);
    gap: 22px;
    padding: 18px;
    position: relative;
    overflow: hidden;
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
  }

  .music-card::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    border-radius: inherit;
    background: linear-gradient(90deg, rgba(217, 210, 255, 0.08), transparent 38%);
    opacity: 0;
    transition: opacity 160ms ease;
  }

  .music-card:hover,
  .music-card:focus-visible {
    transform: translateY(-3px);
    border-color: rgba(217, 210, 255, 0.44);
    background: linear-gradient(145deg, rgba(12, 15, 34, 0.9), rgba(8, 10, 24, 0.62));
  }

  .music-card:hover::after,
  .music-card:focus-visible::after {
    opacity: 1;
  }

  .cover {
    display: grid;
    place-items: center;
    aspect-ratio: 1;
    overflow: hidden;
    border: 1px solid rgba(236, 238, 255, 0.16);
    border-radius: 18px;
    background: linear-gradient(135deg, #f5f2ff, #aebcff 58%, #d7b4c7);
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.32);
  }

  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cover span {
    color: #080914;
    font-size: 2.5rem;
    font-weight: 950;
    letter-spacing: -0.12em;
  }

  .content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 0;
  }

  .meta {
    margin: 0 0 8px;
    color: var(--accent-2);
    font-size: 0.74rem;
    font-weight: 850;
    letter-spacing: 0.16em;
  }

  .title-row {
    display: flex;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 10px;
  }

  h2 {
    margin: 0;
    font-size: clamp(1.5rem, 3.6vw, 2.45rem);
    line-height: 1;
    letter-spacing: -0.06em;
  }

  .badge {
    border: 1px solid rgba(217, 210, 255, 0.28);
    border-radius: 999px;
    color: var(--accent);
    background: rgba(7, 8, 18, 0.54);
    padding: 7px 10px;
    font-size: 0.68rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .content p:not(.meta) {
    margin: 0 0 16px;
    color: var(--muted);
    line-height: 1.65;
  }

  .open {
    color: var(--accent);
    font-size: 0.82rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @media (max-width: 680px) {
    .music-card {
      grid-template-columns: 1fr;
    }
  }
</style>
